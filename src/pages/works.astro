---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProjects } from '../lib/content.js';
import site from '../data/site.json';

const projects = getProjects();
const year = new Date().getFullYear();

/*
  手机版保持两列瀑布流：
  1 左、2 右、3 左、4 右……
*/
const mobileColumns = [[], []];

projects.forEach((project, index) => {
  mobileColumns[index % 2].push(project);
});
---

<BaseLayout
  title="Works"
  showChrome={false}
  bodyClass="sq-works-page"
>
  <div class="sq-works-layout">

    <aside class="sq-works-sidebar">
      <a class="sq-works-name" href="/">
        {site.name}
      </a>

      <div class="sq-works-sidebar-bottom">
        <nav aria-label="Main navigation">
          <a href="/works/">Works.</a>
          <a href="/information/">Information.</a>
        </nav>

        <p class="sq-desktop-copyright">
          © {year}
        </p>
      </div>
    </aside>

    <!-- 电脑端：普通三列网格 -->
    <section
      class="sq-desktop-grid"
      aria-label="Projects"
    >
      {
        projects.map((project) => (
          <article class="sq-desktop-item">
            <a
              class="sq-work-link"
              href={`/projects/${project.slug}/`}
            >
              <figure class="sq-desktop-figure">
                <img
                  class="sq-desktop-cover"
                  src={project.cover}
                  alt={project.title}
                  loading="lazy"
                />

                <figcaption class="sq-desktop-caption">
                  {project.title}
                  {project.year ? `, ${project.year}` : ''}
                </figcaption>
              </figure>
            </a>
          </article>
        ))
      }
    </section>

    <!-- 手机版：保持现在的两列瀑布流 -->
    <section
      class="sq-mobile-masonry"
      aria-label="Projects"
    >
      {
        mobileColumns.map((column) => (
          <div class="sq-mobile-column">
            {
              column.map((project) => (
                <article class="sq-mobile-item">
                  <a
                    class="sq-work-link"
                    href={`/projects/${project.slug}/`}
                  >
                    <figure class="sq-mobile-figure">
                      <img
                        class="sq-mobile-cover"
                        src={project.cover}
                        alt={project.title}
                        loading="lazy"
                      />

                      <figcaption class="sq-mobile-caption">
                        {project.title}
                        {project.year ? `, ${project.year}` : ''}
                      </figcaption>
                    </figure>
                  </a>
                </article>
              ))
            }
          </div>
        ))
      }
    </section>

    <p class="sq-mobile-copyright">
      © {year}
    </p>

  </div>
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    background: #ffffff;
    color: #111111;
  }

  :global(body.sq-works-page) {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.25;
  }

  :global(body.sq-works-page .skip-link) {
    position: fixed;
    top: -1000px;
    left: -1000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .sq-works-layout {
    min-height: 100svh;
    background: #ffffff;
  }

  /* ---------- 左侧导航 ---------- */

  .sq-works-sidebar {
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    z-index: 20;
    width: 180px;
    height: 100svh;
    padding: 10px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: #ffffff;
  }

  .sq-works-name,
  .sq-works-sidebar a,
  .sq-work-link {
    color: #111111;
    text-decoration: none;
  }

  .sq-works-name:hover,
  .sq-works-sidebar a:hover,
  .sq-work-link:hover {
    opacity: 0.55;
  }

  .sq-works-sidebar-bottom nav {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin: 0 0 28px;
  }

  .sq-desktop-copyright {
    margin: 0;
  }

  .sq-mobile-copyright {
    display: none;
  }

  /* ---------- 电脑端三列 ---------- */

  .sq-desktop-grid {
    margin-left: 180px;
    padding: 34px 52px 130px 38px;
    box-sizing: border-box;

    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));

    column-gap: clamp(42px, 5vw, 82px);
    row-gap: clamp(74px, 8vw, 120px);

    align-items: start;
  }

  .sq-desktop-item {
    width: 100%;
    min-width: 0;

    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  .sq-desktop-item .sq-work-link {
    display: flex;
    width: 100%;
    justify-content: center;
  }

  /*
    Figure 按照图片实际宽度收缩。
    标题因此会和图片左边缘对齐，
    而不是和整列左边缘对齐。
  */
  .sq-desktop-figure {
    display: flex;
    width: fit-content;
    max-width: 100%;
    margin: 0;
    padding: 0;

    flex-direction: column;
    align-items: flex-start;
  }

  .sq-desktop-cover {
    display: block;

    width: auto;
    max-width: 100%;

    height: auto;
    max-height: 68svh;

    object-fit: contain;
  }

  .sq-desktop-caption {
    display: block;
    width: 100%;
    margin: 7px 0 0;
    padding: 0;
    text-align: left;
  }

  /* 中等尺寸电脑和平板横屏 */

  @media (max-width: 1050px) and (min-width: 701px) {
    .sq-desktop-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 44px;
    }

    .sq-desktop-cover {
      max-height: 72svh;
    }
  }

  /* ---------- 手机版默认隐藏 ---------- */

  .sq-mobile-masonry {
    display: none;
  }

  /* ---------- 手机版 ---------- */

  @media (max-width: 700px) {
    .sq-works-sidebar {
      position: relative;
      width: 100%;
      height: 118px;
      min-height: 118px;
      padding: 12px;
      display: block;
    }

    .sq-works-name {
      position: absolute;
      top: 12px;
      left: 12px;
    }

    .sq-works-sidebar-bottom {
      position: absolute;
      top: 52px;
      left: 12px;
      margin: 0;
    }

    .sq-works-sidebar-bottom nav {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      margin: 0;
    }

    .sq-desktop-copyright {
      display: none;
    }

    .sq-desktop-grid {
      display: none;
    }

    /*
      保留你目前满意的手机版：
      两列独立排列、图片不裁剪、减少大块空白。
    */
    .sq-mobile-masonry {
      display: flex;
      width: 100%;
      margin: 0;
      padding: 18px 16px 36px;
      box-sizing: border-box;

      align-items: flex-start;
      gap: 20px;
    }

    .sq-mobile-column {
      width: calc(50% - 10px);
      min-width: 0;
      flex: 0 0 calc(50% - 10px);
    }

    .sq-mobile-item {
      width: 100%;
      margin: 0 0 42px;
    }

    .sq-mobile-figure {
      display: block;
      width: 100%;
      margin: 0;
      padding: 0;
    }

    .sq-mobile-cover {
      display: block;
      width: 100%;
      height: auto;
      object-fit: contain;
    }

    .sq-mobile-caption {
      display: block;
      width: 100%;
      margin: 7px 0 0;
      padding: 0;

      text-align: left;
      font-size: 11px;
      line-height: 1.2;
    }

    .sq-mobile-copyright {
      display: block;
      margin: 0;
      padding:
        0
        16px
        calc(18px + env(safe-area-inset-bottom));

      font-size: 10px;
    }
  }
</style>
