---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProjects } from '../lib/content.js';
import site from '../data/site.json';

const projects = getProjects();
const year = new Date().getFullYear();
---

<BaseLayout
  title="Works"
  showChrome={false}
  bodyClass="sq-works-body"
>
  <div class="sq-works-page">

    <aside class="sq-works-sidebar">
      <a class="sq-works-name" href="/">
        {site.name}
      </a>

      <div class="sq-works-sidebar-bottom">
        <nav aria-label="Main navigation">
          <a href="/works/">Works.</a>
          <a href="/information/">Information.</a>
        </nav>

        <p>© {year}</p>
      </div>
    </aside>

    <!-- 电脑端：统一画框，完整显示图片 -->
    <section
      class="sq-desktop-grid"
      aria-label="Projects"
    >
      {
        projects.map((project) => (
          <article class="sq-desktop-item">
            <a
              class="sq-project-link"
              href={`/projects/${project.slug}/`}
            >
              <div class="sq-desktop-frame">
                <img
                  src={project.cover}
                  alt={project.title}
                  loading="lazy"
                />
              </div>

              <p class="sq-project-caption">
                {project.title}
                {project.year ? `, ${project.year}` : ''}
              </p>
            </a>
          </article>
        ))
      }
    </section>

    <!-- 手机版：两列，保持图片原始比例 -->
    <section
      class="sq-mobile-columns"
      aria-label="Projects"
    >
      {
        projects.map((project) => (
          <article class="sq-mobile-item">
            <a
              class="sq-project-link"
              href={`/projects/${project.slug}/`}
            >
              <img
                class="sq-mobile-cover"
                src={project.cover}
                alt={project.title}
                loading="lazy"
              />

              <p class="sq-mobile-caption">
                {project.title}
                {project.year ? `, ${project.year}` : ''}
              </p>
            </a>
          </article>
        ))
      }
    </section>

  </div>
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    background: #ffffff;
    color: #111111;
  }

  :global(body.sq-works-body) {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.25;
  }

  :global(body.sq-works-body .skip-link) {
    position: fixed;
    top: -1000px;
    left: -1000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .sq-works-page {
    min-height: 100svh;
    background: #ffffff;
  }

  /* ---------- 左侧导航 ---------- */

  .sq-works-sidebar {
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    z-index: 20;
    width: 180px;
    height: 100svh;
    padding: 10px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: #ffffff;
  }

  .sq-works-name,
  .sq-works-sidebar a,
  .sq-project-link {
    color: #111111;
    text-decoration: none;
  }

  .sq-works-name:hover,
  .sq-works-sidebar a:hover,
  .sq-project-link:hover {
    opacity: 0.52;
  }

  .sq-works-sidebar-bottom nav {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin: 0 0 28px;
  }

  .sq-works-sidebar-bottom p {
    margin: 0;
  }

  /* ---------- 电脑端 ---------- */

  .sq-desktop-grid {
    margin-left: 180px;
    padding: 30px 46px 130px 34px;
    box-sizing: border-box;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    column-gap: clamp(34px, 4vw, 68px);
    row-gap: 82px;
    align-items: start;
  }

  .sq-desktop-item {
    min-width: 0;
    width: 100%;
  }

  /*
    所有项目使用相同高度的隐形白色画框。
    图片使用 contain，因此绝对不会被裁切。
  */
  .sq-desktop-frame {
    width: 100%;
    height: clamp(320px, 32vw, 500px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #ffffff;
  }

  .sq-desktop-frame img {
    display: block;
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .sq-project-caption {
    margin: 8px 0 0;
    text-align: left;
  }

  .sq-mobile-columns {
    display: none;
  }

  /* ---------- 中等电脑 / 平板 ---------- */

  @media (max-width: 1050px) and (min-width: 701px) {
    .sq-desktop-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .sq-desktop-frame {
      height: clamp(340px, 46vw, 520px);
    }
  }

  /* ---------- 手机版：保持现有两列感觉 ---------- */

  @media (max-width: 700px) {
    .sq-works-sidebar {
      position: relative;
      width: 100%;
      height: 118px;
      min-height: 118px;
      padding: 12px;
      display: block;
    }

    .sq-works-name {
      position: absolute;
      top: 12px;
      left: 12px;
    }

    .sq-works-sidebar-bottom {
      position: absolute;
      top: 52px;
      left: 12px;
      margin: 0;
    }

    .sq-works-sidebar-bottom nav {
      margin: 0;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
    }

    .sq-works-sidebar-bottom p {
      position: fixed;
      bottom: 12px;
      left: 12px;
      z-index: 30;
      margin: 0;
      padding-right: 5px;
      background: rgba(255, 255, 255, 0.96);
      font-size: 10px;
    }

    .sq-desktop-grid {
      display: none;
    }

    .sq-mobile-columns {
      display: block;
      width: 100%;
      margin: 0;
      padding: 18px 16px 80px;
      box-sizing: border-box;
      column-count: 2;
      column-gap: 20px;
    }

    .sq-mobile-item {
      display: inline-block;
      width: 100%;
      margin: 0 0 52px;
      break-inside: avoid;
      vertical-align: top;
    }

    .sq-mobile-cover {
      display: block;
      width: 100%;
      height: auto;
      object-fit: contain;
    }

    .sq-mobile-caption {
      margin: 7px 0 0;
      text-align: center;
      font-size: 11px;
      line-height: 1.2;
    }
  }@media (min-width: 701px) {
  .sq-desktop-frame {
    align-items: flex-end;
  }

  .sq-project-caption {
    margin-top: 8px;
  }
}
</style>
