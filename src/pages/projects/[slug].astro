---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProjects } from '../../lib/content.js';

export function getStaticPaths() {
  return getProjects().map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
---
<BaseLayout title={project.title} description={project.description} bodyClass="project-page">
  <article class="project-detail">
    <header class="project-heading">
      <p>{project.category} / {project.year}</p>
      <h1>{project.title}</h1>
      <p>{project.client}</p>
    </header>

    <div class="project-gallery">
      {[project.cover, ...(project.gallery || [])].map((image, index) => (
        <figure class:list={[index > 0 && index % 3 === 0 && 'gallery-inset']}>
          <img src={image} alt={`${project.title}, image ${index + 1}`} loading={index < 2 ? 'eager' : 'lazy'} />
          <figcaption>{String(index + 1).padStart(2, '0')}</figcaption>
        </figure>
      ))}
    </div>

    <section class="project-information">
      <div class="project-description">
        <h2>Project</h2>
        <p>{project.description}</p>
      </div>
      <div class="project-credits">
        <h2>Credits</h2>
        <dl>
          {project.credits?.map((credit) => (
            <div>
              <dt>{credit.role}</dt>
              <dd>{credit.name}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <nav class="project-end" aria-label="Project navigation">
      <a href="/works/">Works</a><span aria-hidden="true">,</span>
      <a href="/information/">Information.</a>
    </nav>
  </article>
</BaseLayout>
