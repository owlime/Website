---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProjects } from '../lib/content.js';
import site from '../data/site.json';

const projects = getProjects();
const year = new Date().getFullYear();

/*
  分别为电脑和手机建立独立瀑布流列。
  项目顺序仍然按照 CMS 中的 order 排列。
*/
const desktopColumns = [[], [], []];
const mobileColumns = [[], []];

projects.forEach((project, index) => {
  desktopColumns[index % 3].push(project);
  mobileColumns[index % 2].push(project);
});
---

<BaseLayout
  title="Works"
  showChrome={false}
  bodyClass="sq-works-page"
>
  <main class="sq-works-layout">

    <aside class="sq-works-sidebar">
      <a class="sq-works-name" href="/">
        {site.name}
      </a>

      <div class="sq-works-sidebar-bottom">
        <nav aria-label="Main navigation">
          <a href="/works/">Works.</a>
          <a href="/information/">Information.</a>
        </nav>

        <p>© {year}</p>
      </div>
    </aside>

    <!-- 电脑版：三列瀑布流 -->
    <section
      class="sq-masonry sq-masonry-desktop"
      aria-label="Projects"
    >
      {
        desktopColumns.map((column) => (
          <div class="sq-masonry-column">
            {
              column.map((project) => (
                <article class="sq-work-item">
                  <a
                    class="sq-work-link"
                    href={`/projects/${project.slug}/`}
                  >
                    <img
                      class="sq-work-cover"
                      src={project.cover}
                      alt={project.title}
                      loading="lazy"
                    />

                    <p class="sq-work-caption">
                      {project.title}
                      {project.year ? `, ${project.year}` : ''}
                    </p>
                  </a>
                </article>
              ))
            }
          </div>
        ))
      }
    </section>

    <!-- 手机版：两列瀑布流 -->
    <section
      class="sq-masonry sq-masonry-mobile"
      aria-label="Projects"
    >
      {
        mobileColumns.map((column) => (
          <div class="sq-masonry-column">
            {
              column.map((project) => (
                <article class="sq-work-item">
                  <a
                    class="sq-work-link"
                    href={`/projects/${project.slug}/`}
                  >
                    <img
                      class="sq-work-cover"
                      src={project.cover}
                      alt={project.title}
                      loading="lazy"
                    />

                    <p class="sq-work-caption">
                      {project.title}
                      {project.year ? `, ${project.year}` : ''}
                    </p>
                  </a>
                </article>
              ))
            }
          </div>
        ))
      }
    </section>

  </main>
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    background: #ffffff;
    color: #111111;
  }

  :global(body.sq-works-page) {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.25;
  }

  /*
    BaseLayout 目前仍然包含 Skip to content。
    在 Works 页面将其隐藏，避免左上角再次出现。
  */
  :global(body.sq-works-page .skip-link) {
    position: fixed;
    top: -1000px;
    left: -1000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .sq-works-layout {
    min-height: 100svh;
    background: #ffffff;
  }

  /* ---------- DESKTOP SIDEBAR ---------- */

  .sq-works-sidebar {
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    z-index: 20;
    width: 180px;
    height: 100svh;
    padding: 10px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: #ffffff;
  }

  .sq-works-name,
  .sq-works-sidebar a,
  .sq-work-link {
    color: #111111;
    text-decoration: none;
  }

  .sq-works-name:hover,
  .sq-works-sidebar a:hover,
  .sq-work-link:hover {
    opacity: 0.55;
  }

  .sq-works-sidebar-bottom nav {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin: 0 0 28px;
  }

  .sq-works-sidebar-bottom p {
    margin: 0;
  }

  /* ---------- MASONRY ---------- */

  .sq-masonry {
    box-sizing: border-box;
  }

  .sq-masonry-desktop {
    margin-left: 180px;
    padding: 34px 54px 130px 38px;
    display: flex;
    align-items: flex-start;
    gap: clamp(40px, 4.5vw, 76px);
  }

  .sq-masonry-mobile {
    display: none;
  }

  .sq-masonry-column {
    flex: 1 1 0;
    min-width: 0;
  }

  .sq-work-item {
    width: 100%;
    margin: 0 0 clamp(80px, 9vw, 135px);
  }

  .sq-work-link {
    display: block;
  }

  .sq-work-cover {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .sq-work-caption {
    margin: 7px 0 0;
    text-align: left;
  }

  /* ---------- MOBILE ---------- */

  @media (max-width: 700px) {
    .sq-works-sidebar {
      position: relative;
      width: 100%;
      height: 86px;
      min-height: 86px;
      padding: 12px;
      display: block;
    }

    .sq-works-name {
      position: absolute;
      top: 12px;
      left: 12px;
    }

    .sq-works-sidebar-bottom {
      position: absolute;
      top: 12px;
      right: 12px;
      left: auto;
      display: flex;
      align-items: baseline;
      gap: 10px;
      margin: 0;
    }

    .sq-works-sidebar-bottom nav {
      display: flex;
      flex-direction: row;
      align-items: baseline;
      gap: 4px;
      margin: 0;
    }

    .sq-works-sidebar-bottom p {
      margin: 0;
      white-space: nowrap;
    }

    .sq-masonry-desktop {
      display: none;
    }

    .sq-masonry-mobile {
      width: 100%;
      margin: 0;
      padding: 14px 20px 80px;
      display: flex;
      align-items: flex-start;
      gap: 22px;
    }

    .sq-masonry-column {
      width: calc(50% - 11px);
      flex: 0 0 calc(50% - 11px);
    }

    .sq-work-item {
      margin-bottom: 56px;
    }

    .sq-work-cover {
      width: 100%;
      height: auto;
      object-fit: contain;
    }

    .sq-work-caption {
      margin-top: 7px;
      text-align: center;
      font-size: 11px;
      line-height: 1.2;
    }
  }
</style>
