---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProjects } from '../lib/content.js';
import site from '../data/site.json';

const projects = getProjects();
const year = new Date().getFullYear();

/*
  手机版保持两列独立排列：
  1 左、2 右、3 左、4 右……
*/
const mobileColumns = [[], []];

projects.forEach((project, index) => {
  mobileColumns[index % 2].push(project);
});
---

<BaseLayout
  title="Works"
  showChrome={false}
  bodyClass="sq-works-page"
>
  <div class="sq-works-layout">

    <aside class="sq-works-sidebar">
      <a class="sq-works-name" href="/">
        {site.name}
      </a>

      <div class="sq-works-sidebar-bottom">
        <nav aria-label="Main navigation">
          <a href="/works/">Works.</a>
          <a href="/information/">Information.</a>
        </nav>

        <p class="sq-desktop-copyright">
          © {year}
        </p>
      </div>
    </aside>

    <!-- 电脑端：三列正常顺序 -->
    <section
      class="sq-desktop-grid"
      aria-label="Projects"
    >
      {
        projects.map((project) => (
          <article class="sq-desktop-item">
            <a
              class="sq-work-link"
              href={`/projects/${project.slug}/`}
            >
              <figure class="sq-desktop-figure">
                <img
                  class="sq-desktop-cover"
                  src={project.cover}
                  alt={project.title}
                  loading="lazy"
                />

                <figcaption class="sq-desktop-caption">
                  {project.title}
                  {project.year ? `, ${project.year}` : ''}
                </figcaption>
              </figure>
            </a>
          </article>
        ))
      }
    </section>

    <!-- 手机版：保持当前两列效果 -->
    <section
      class="sq-mobile-masonry"
      aria-label="Projects"
    >
      {
        mobileColumns.map((column) => (
          <div class="sq-mobile-column">
            {
              column.map((project) => (
                <article class="sq-mobile-item">
                  <a
                    class="sq-work-link"
                    href={`/projects/${project.slug}/`}
                  >
                    <figure class="sq-mobile-figure">
                      <img
                        class="sq-mobile-cover"
                        src={project.cover}
                        alt={project.title}
                        loading="lazy"
                      />

                      <figcaption class="sq-mobile-caption">
                        {project.title}
                        {project.year ? `, ${project.year}` : ''}
                      </figcaption>
                    </figure>
                  </a>
                </article>
              ))
            }
          </div>
        ))
      }
    </section>

    <p class="sq-mobile-copyright">
      © {year}
    </p>

  </div>

  <script>
    const desktopImages =
      document.querySelectorAll('.sq-desktop-cover');

    const setImageOrientation = (image) => {
      if (!(image instanceof HTMLImageElement)) return;

      const figure = image.closest('.sq-desktop-figure');
      if (!figure) return;

      figure.classList.remove(
        'is-landscape',
        'is-square',
        'is-portrait'
      );

      const width = image.naturalWidth;
      const height = image.naturalHeight;

      if (!width || !height) return;

      const ratio = width / height;

      if (ratio > 1.12) {
        figure.classList.add('is-landscape');
      } else if (ratio < 0.88) {
        figure.classList.add('is-portrait');
      } else {
        figure.classList.add('is-square');
      }
    };

    desktopImages.forEach((image) => {
      if (!(image instanceof HTMLImageElement)) return;

      if (image.complete && image.naturalWidth) {
        setImageOrientation(image);
      } else {
        image.addEventListener(
          'load',
          () => setImageOrientation(image),
          { once: true }
        );
      }
    });
  </script>
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    background: #ffffff;
    color: #111111;
  }

  :global(body.sq-works-page) {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.25;
  }

  :global(body.sq-works-page .skip-link) {
    position: fixed;
    top: -1000px;
    left: -1000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .sq-works-layout {
    min-height: 100svh;
    background: #ffffff;
  }

  /* ---------- 左侧导航 ---------- */

  .sq-works-sidebar {
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    z-index: 20;

    width: 180px;
    height: 100svh;
    padding: 10px;
    box-sizing: border-box;

    display: flex;
    flex-direction: column;
    justify-content: space-between;

    background: #ffffff;
  }

  .sq-works-name,
  .sq-works-sidebar a,
  .sq-work-link {
    color: #111111;
    text-decoration: none;
  }

  .sq-works-name:hover,
  .sq-works-sidebar a:hover,
  .sq-work-link:hover {
    opacity: 0.55;
  }

  .sq-works-sidebar-bottom nav {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin: 0 0 28px;
  }

  .sq-desktop-copyright {
    margin: 0;
  }

  .sq-mobile-copyright {
    display: none;
  }

  /* ---------- 电脑端三列 ---------- */

  .sq-desktop-grid {
    margin-left: 180px;
    padding: 24px 48px 120px 36px;
    box-sizing: border-box;

    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));

    column-gap: clamp(36px, 4vw, 64px);
    row-gap: clamp(50px, 5vw, 76px);

    align-items: start;
  }

  .sq-desktop-item {
    width: 100%;
    min-width: 0;

    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  .sq-desktop-item .sq-work-link {
    display: flex;
    width: 100%;
    justify-content: center;
  }

  /*
    默认先按竖图宽度显示。
    图片加载后，JavaScript 会自动判断方向。
  */
  .sq-desktop-figure {
    display: flex;
    width: 68%;
    max-width: 100%;
    margin: 0;
    padding: 0;

    flex-direction: column;
    align-items: flex-start;
  }

  /*
    横图占满整列。
    这样横图的视觉高度会明显增大。
  */
  .sq-desktop-figure.is-landscape {
    width: 100%;
  }

  /*
    方图在横图与竖图之间。
  */
  .sq-desktop-figure.is-square {
    width: 82%;
  }

  /*
    竖图使用约三分之二列宽。
    这样不会比横图大得过分。
  */
  .sq-desktop-figure.is-portrait {
    width: 68%;
  }

  .sq-desktop-cover {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .sq-desktop-figure.is-landscape .sq-desktop-cover {
    max-height: 39svh;
  }

  .sq-desktop-figure.is-square .sq-desktop-cover {
    max-height: 48svh;
  }

  .sq-desktop-figure.is-portrait .sq-desktop-cover {
    max-height: 58svh;
  }

  .sq-desktop-caption {
    display: block;
    width: 100%;
    margin: 7px 0 0;
    padding: 0;
    text-align: left;
  }

  /* 中等屏幕 */

  @media (max-width: 1050px) and (min-width: 701px) {
    .sq-desktop-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 42px;
    }

    .sq-desktop-figure.is-landscape {
      width: 100%;
    }

    .sq-desktop-figure.is-square {
      width: 80%;
    }

    .sq-desktop-figure.is-portrait {
      width: 66%;
    }
  }

  /* ---------- 手机版默认隐藏 ---------- */

  .sq-mobile-masonry {
    display: none;
  }

  /* ---------- 手机版：保持原样 ---------- */

  @media (max-width: 700px) {
    .sq-works-sidebar {
      position: relative;
      width: 100%;
      height: 118px;
      min-height: 118px;
      padding: 12px;
      display: block;
    }

    .sq-works-name {
      position: absolute;
      top: 12px;
      left: 12px;
    }

    .sq-works-sidebar-bottom {
      position: absolute;
      top: 52px;
      left: 12px;
      margin: 0;
    }

    .sq-works-sidebar-bottom nav {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      margin: 0;
    }

    .sq-desktop-copyright {
      display: none;
    }

    .sq-desktop-grid {
      display: none;
    }

    .sq-mobile-masonry {
      display: flex;
      width: 100%;
      margin: 0;
      padding: 18px 16px 36px;
      box-sizing: border-box;

      align-items: flex-start;
      gap: 20px;
    }

    .sq-mobile-column {
      width: calc(50% - 10px);
      min-width: 0;
      flex: 0 0 calc(50% - 10px);
    }

    .sq-mobile-item {
      width: 100%;
      margin: 0 0 42px;
    }

    .sq-mobile-figure {
      display: block;
      width: 100%;
      margin: 0;
      padding: 0;
    }

    .sq-mobile-cover {
      display: block;
      width: 100%;
      height: auto;
      object-fit: contain;
    }

    .sq-mobile-caption {
      display: block;
      width: 100%;
      margin: 7px 0 0;
      padding: 0;

      text-align: left;
      font-size: 11px;
      line-height: 1.2;
    }

    .sq-mobile-copyright {
      display: block;
      margin: 0;
      padding:
        0
        16px
        calc(18px + env(safe-area-inset-bottom));

      font-size: 10px;
    }
  }  /* Desktop spacing and consistent image rhythm */
  @media (min-width: 701px) {
    .sq-desktop-grid {
      column-gap: clamp(28px, 3vw, 46px);
      row-gap: 30px;
      padding-top: 22px;
      padding-right: 38px;
    }

    .sq-desktop-figure {
      display: grid;
      grid-template-rows: 52svh auto;
      align-items: end;
    }

    .sq-desktop-cover {
      align-self: end;
    }

    .sq-desktop-figure.is-landscape .sq-desktop-cover {
      max-height: 35svh;
    }

    .sq-desktop-figure.is-square .sq-desktop-cover {
      max-height: 44svh;
    }

    .sq-desktop-figure.is-portrait .sq-desktop-cover {
      max-height: 52svh;
    }

    .sq-desktop-caption {
      align-self: start;
      margin-top: 7px;
    }
  }  /* Desktop: align every image and caption to its column's left edge */
  @media (min-width: 701px) {
    .sq-desktop-item {
      justify-content: flex-start;
    }

    .sq-desktop-item .sq-work-link {
      justify-content: flex-start;
    }

    .sq-desktop-figure {
      margin-left: 0;
      margin-right: auto;
    }

    .sq-desktop-caption {
      text-align: left;
    }
  }
</style>
