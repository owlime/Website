---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';

const year = new Date().getFullYear();
---

<BaseLayout showChrome={false} bodyClass="shenqu-home-page">
  <section class="shenqu-home">

    <div class="shenqu-identity">
      <a href="/">{site.name}</a>

      <div class="shenqu-description">
        <p>{site.headline}</p>
        <p>{site.location}</p>
      </div>
    </div>

    <nav class="shenqu-navigation" aria-label="Main navigation">
      <a href="/works/">Works</a>
      <span>,</span>
      <a href="/information/">Information.</a>
    </nav>

    <a
      class="shenqu-video"
      href="/works/"
      aria-label="Open works gallery"
    >
      <video
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      >
        <source
          src="/uploads/Home%20Video.mp4"
          type="video/mp4"
        />
      </video>
    </a>

    <div class="shenqu-copyright">
      © {year}
    </div>

  </section>
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: #ffffff;
  }

  .shenqu-home {
    position: relative;
    width: 100%;
    height: 100svh;
    overflow: hidden;
    background: #ffffff;
    color: #111111;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 13px;
    font-weight: 400;
    line-height: 1.25;
  }

  .shenqu-identity {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 10;
  }

  .shenqu-identity a,
  .shenqu-navigation a {
    color: inherit;
    text-decoration: none;
  }

  .shenqu-description {
    margin-top: 18px;
  }

  .shenqu-description p {
    margin: 0 0 4px;
  }

  .shenqu-navigation {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 10;
    display: flex;
    gap: 4px;
  }

  .shenqu-video {
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(48vw, 720px);
    height: min(76svh, 820px);
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .shenqu-video video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .shenqu-copyright {
    position: absolute;
    bottom: 10px;
    left: 10px;
    z-index: 10;
    font-size: 10px;
  }

  @media (max-width: 700px) {
    .shenqu-home {
      font-size: 12px;
    }

    .shenqu-description {
      margin-top: 14px;
    }

    .shenqu-video {
      width: calc(100vw - 36px);
      height: 62svh;
    }
  }
</style>
