---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';

const year = new Date().getFullYear();
const fallbackVideo = '/uploads/Home%20Video.mp4';
const homepage = site.homepage ?? {};

const createMedia = (type, image, video, fallback) => {
  if (type === 'image' && image) {
    return { type: 'image', src: image };
  }

  if (type === 'video' && video) {
    return { type: 'video', src: video };
  }

  return fallback;
};

const desktopType = homepage.desktopType === 'image' ? 'image' : 'video';

const desktopMedia = createMedia(
  desktopType,
  homepage.desktopImage,
  homepage.desktopVideo,
  {
    type: 'video',
    src: homepage.desktopVideo || fallbackVideo
  }
);

const mobileMode = ['image', 'video'].includes(homepage.mobileType)
  ? homepage.mobileType
  : 'same';

const mobileMedia =
  mobileMode === 'same'
    ? desktopMedia
    : createMedia(
        mobileMode,
        homepage.mobileImage,
        homepage.mobileVideo,
        desktopMedia
      );

const desktopFit =
  homepage.desktopFit === 'cover' ? 'cover' : 'contain';

const mobileFit =
  homepage.mobileFit === 'cover' || homepage.mobileFit === 'contain'
    ? homepage.mobileFit
    : desktopFit;

const desktopPoster =
  homepage.desktopPoster ||
  homepage.desktopImage ||
  undefined;

const mobilePoster =
  homepage.mobilePoster ||
  homepage.mobileImage ||
  homepage.desktopPoster ||
  homepage.desktopImage ||
  undefined;
---

<BaseLayout
  title="SHEN QU"
  showChrome={false}
  bodyClass="landing-page"
>
  <section class="sq-cms-home" aria-label="Portfolio entrance">
    <a class="sq-cms-home-name" href="/">
      {site.name}
    </a>

    <nav class="sq-cms-home-nav" aria-label="Main navigation">
      <a href="/works/">Works.</a>
      <a href="/information/">Information.</a>
    </nav>

    <a
      class:list={[
        'sq-cms-home-media',
        'sq-cms-home-media-desktop',
        `fit-${desktopFit}`
      ]}
      href="/works/"
      aria-label="Enter works"
    >
      {
        desktopMedia.type === 'image' ? (
          <img
            src={desktopMedia.src}
            alt="Enter the SHEN QU portfolio"
            loading="eager"
            fetchpriority="high"
          />
        ) : (
          <video
            class="sq-cms-home-video"
            autoplay
            muted
            loop
            playsinline
            webkit-playsinline
            preload="auto"
            poster={desktopPoster}
            disablepictureinpicture
            controlslist="nodownload noplaybackrate noremoteplayback"
          >
            <source src={desktopMedia.src} type="video/mp4" />
          </video>
        )
      }
    </a>

    <a
      class:list={[
        'sq-cms-home-media',
        'sq-cms-home-media-mobile',
        `fit-${mobileFit}`
      ]}
      href="/works/"
      aria-label="Enter works"
    >
      {
        mobileMedia.type === 'image' ? (
          <img
            src={mobileMedia.src}
            alt="Enter the SHEN QU portfolio"
            loading="eager"
            fetchpriority="high"
          />
        ) : (
          <video
            class="sq-cms-home-video"
            autoplay
            muted
            loop
            playsinline
            webkit-playsinline
            preload="auto"
            poster={mobilePoster}
            disablepictureinpicture
            controlslist="nodownload noplaybackrate noremoteplayback"
          >
            <source src={mobileMedia.src} type="video/mp4" />
          </video>
        )
      }
    </a>

    <p class="sq-cms-home-copyright">
      © {year}
    </p>
  </section>

  <script>
    const videos = document.querySelectorAll('.sq-cms-home-video');

    videos.forEach((video) => {
      if (!(video instanceof HTMLVideoElement)) return;

      video.muted = true;
      video.defaultMuted = true;
      video.playsInline = true;

      const tryPlay = async () => {
        try {
          await video.play();
        } catch {
          // iPhone Low Power Mode may still block autoplay.
        }
      };

      if (video.readyState >= 2) {
        tryPlay();
      }

      video.addEventListener('loadedmetadata', tryPlay);
      video.addEventListener('canplay', tryPlay);
      window.addEventListener('pageshow', tryPlay);

      document.addEventListener('visibilitychange', () => {
        if (!document.hidden) tryPlay();
      });
    });
  </script>
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    background: #ffffff;
    color: #111111;
  }

  :global(body.landing-page) {
    overflow: hidden;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.25;
  }

  :global(body.landing-page .skip-link) {
    position: fixed;
    top: -1000px;
    left: -1000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .sq-cms-home {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 100svh;
    overflow: hidden;
    background: #ffffff;
  }

  .sq-cms-home-name {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 30;
    color: #111111;
    text-decoration: none;
  }

  .sq-cms-home-nav {
    position: absolute;
    top: 50%;
    left: 10px;
    z-index: 30;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    transform: translateY(-50%);
  }

  .sq-cms-home-nav a {
    color: #111111;
    text-decoration: none;
  }

  .sq-cms-home-name:hover,
  .sq-cms-home-nav a:hover {
    opacity: 0.5;
  }

  .sq-cms-home-media {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-decoration: none;
    background: transparent;
  }

  .sq-cms-home-media-desktop {
    top: 50%;
    left: 61%;
    width: min(36vw, 580px);
    height: calc(100svh - 120px);
    transform: translate(-50%, -50%);
  }

  .sq-cms-home-media-mobile {
    display: none;
  }

  .sq-cms-home-media img,
  .sq-cms-home-media video {
    display: block;
    width: 100%;
    height: 100%;
  }

  .sq-cms-home-media.fit-contain img,
  .sq-cms-home-media.fit-contain video {
    object-fit: contain;
  }

  .sq-cms-home-media.fit-cover img,
  .sq-cms-home-media.fit-cover video {
    object-fit: cover;
  }

  .sq-cms-home-video::-webkit-media-controls {
    display: none !important;
  }

  .sq-cms-home-video::-webkit-media-controls-start-playback-button {
    display: none !important;
    appearance: none;
  }

  .sq-cms-home-copyright {
    position: absolute;
    bottom: 10px;
    left: 10px;
    z-index: 30;
    margin: 0;
    font-size: 10px;
  }

  @media (max-width: 700px) {
    .sq-cms-home-name {
      top: 12px;
      left: 12px;
    }

    .sq-cms-home-nav {
      top: 52px;
      left: 12px;
      transform: none;
    }

    .sq-cms-home-media-desktop {
      display: none;
    }

    .sq-cms-home-media-mobile {
      top: 128px;
      left: 16px;
      width: calc(100vw - 32px);
      height: calc(100svh - 230px);
      transform: none;
      display: flex;
    }

    .sq-cms-home-copyright {
      bottom: 12px;
      left: 12px;
    }
  }
</style>
