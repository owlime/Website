---
import BaseLayout from '../layouts/BaseLayout.astro';

const year = new Date().getFullYear();
---

<BaseLayout
  title="SHEN QU"
  showChrome={false}
  bodyClass="landing-page"
>
  <section class="sq-home" aria-label="Portfolio entrance">
    <a class="sq-home-name" href="/">
      SHEN QU
    </a>

    <nav class="sq-home-nav" aria-label="Main navigation">
      <a href="/works/">Works.</a>
      <a href="/information/">Information.</a>
    </nav>

    <a
      class="sq-home-video-link"
      href="/works/"
      aria-label="Enter works"
    >
      <video
        class="sq-home-video"
        autoplay
        muted
        loop
        playsinline
        webkit-playsinline
        preload="auto"
        disablepictureinpicture
        controlslist="nodownload noplaybackrate noremoteplayback"
      >
        <source
          src="/uploads/Home%20Video.mp4"
          type="video/mp4"
        />
      </video>
    </a>

    <p class="sq-home-copyright">
      © {year}
    </p>
  </section>

  <script>
    const video = document.querySelector('.sq-home-video');

    if (video instanceof HTMLVideoElement) {
      video.muted = true;
      video.defaultMuted = true;
      video.playsInline = true;

      const tryPlay = async () => {
        try {
          await video.play();
        } catch {
          // iPhone 低电量模式可能仍然阻止自动播放。
        }
      };

      if (video.readyState >= 2) {
        tryPlay();
      }

      video.addEventListener('loadedmetadata', tryPlay);
      video.addEventListener('canplay', tryPlay);

      window.addEventListener('pageshow', tryPlay);

      document.addEventListener('visibilitychange', () => {
        if (!document.hidden) {
          tryPlay();
        }
      });

      document.addEventListener(
        'touchstart',
        () => {
          tryPlay();
        },
        { once: true, passive: true }
      );

      document.addEventListener(
        'pointerdown',
        () => {
          tryPlay();
        },
        { once: true }
      );
    }
  </script>
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    background: #ffffff;
    color: #111111;
  }

  :global(body.landing-page) {
    overflow: hidden;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.25;
  }

  :global(body.landing-page .skip-link) {
    position: fixed;
    top: -1000px;
    left: -1000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .sq-home {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 100svh;
    overflow: hidden;
    background: #ffffff;
  }

  .sq-home-name {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 30;
    color: #111111;
    text-decoration: none;
  }

  .sq-home-nav {
    position: absolute;
    top: 50%;
    left: 10px;
    z-index: 30;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    transform: translateY(-50%);
  }

  .sq-home-nav a {
    color: #111111;
    text-decoration: none;
  }

  .sq-home-name:hover,
  .sq-home-nav a:hover {
    opacity: 0.5;
  }

  /* 电脑端：视频较小并向右移动 */
  .sq-home-video-link {
    position: absolute;
    top: 50%;
    left: 61%;
    width: min(36vw, 580px);
    height: calc(100svh - 120px);
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: visible;
    text-decoration: none;
  }

  .sq-home-video {
    display: block;
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    background: transparent;
  }

  .sq-home-video::-webkit-media-controls {
    display: none !important;
  }

  .sq-home-video::-webkit-media-controls-start-playback-button {
    display: none !important;
    appearance: none;
  }

  .sq-home-copyright {
    position: absolute;
    bottom: 10px;
    left: 10px;
    z-index: 30;
    margin: 0;
    font-size: 10px;
  }

  /* 手机版 */
  @media (max-width: 700px) {
    .sq-home-name {
      top: 12px;
      left: 12px;
    }

    .sq-home-nav {
      top: 52px;
      left: 12px;
      transform: none;
    }

    .sq-home-video-link {
      top: 128px;
      left: 16px;
      width: calc(100vw - 32px);
      height: calc(100svh - 230px);
      transform: none;
    }

    .sq-home-video {
      width: 100%;
      height: 100%;
      max-width: none;
      max-height: none;
      object-fit: contain;
    }

    .sq-home-copyright {
      bottom: 12px;
      left: 12px;
    }
  }
</style>
