---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';

const year = new Date().getFullYear();
---

<BaseLayout showChrome={false} bodyClass="shenqu-home-page">
  <main class="home">

    <div class="home-left">
      <a class="home-name" href="/">{site.name}</a>

      <nav class="home-nav" aria-label="Main navigation">
        <a href="/works/">Works.</a>
        <a href="/information/">Information.</a>
      </nav>
    </div>

    <a
      class="home-video"
      href="/works/"
      aria-label="Open works gallery"
    >
      <video
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      >
        <source
          src="/uploads/Home%20Video.mp4"
          type="video/mp4"
        />
      </video>
    </a>

    <p class="home-copyright">© {year}</p>

  </main>
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    width: 100%;
    height: 100%;
    margin: 0;
    overflow: hidden;
    background: #ffffff;
  }

  :global(body.shenqu-home-page) {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 13px;
    font-weight: 400;
    line-height: 1.25;
    color: #111111;
  }

  .home {
    position: relative;
    width: 100%;
    height: 100svh;
    overflow: hidden;
    background: #ffffff;
  }

  .home-left {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 10;
  }

  .home-name,
  .home-nav a {
    color: inherit;
    text-decoration: none;
  }

  .home-nav {
    position: fixed;
    top: 48%;
    left: 10px;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    margin: 0;
  }

  .home-name:hover,
  .home-nav a:hover {
    opacity: 0.5;
  }

  .home-video {
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(48vw, 720px);
    height: min(76svh, 820px);
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .home-video video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .home-copyright {
    position: absolute;
    left: 10px;
    bottom: 10px;
    z-index: 10;
    margin: 0;
    font-size: 10px;
  }

  @media (max-width: 700px) {
    :global(body.shenqu-home-page) {
      font-size: 12px;
    }

    .home-nav {
      top: 46%;
      margin: 0;
    }

    .home-video {
      width: calc(100vw - 36px);
      height: 62svh;
    }
  }
</style>
