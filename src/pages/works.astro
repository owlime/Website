---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProjects } from '../lib/content.js';
import site from '../data/site.json';

const projects = getProjects();
const year = new Date().getFullYear();
---

<BaseLayout title="Works" showChrome={false} bodyClass="works-gallery-page">
  <main class="works-layout">
    <aside class="works-sidebar">
      <a class="works-site-name" href="/">{site.name}</a>

      <div class="works-sidebar-bottom">
        <nav aria-label="Main navigation">
          <a href="/works/">Works.</a>
          <a href="/information/">Information.</a>
        </nav>
        <p>© {year}</p>
      </div>
    </aside>

    <section class="cover-grid" aria-label="Works gallery">
      {
        projects.map((project) => (
          <a class="cover-item" href={`/projects/${project.slug}/`}>
            <figure>
              <div class="cover-media">
                <img
                  src={project.cover}
                  alt={project.title}
                  loading="lazy"
                />
              </div>
              <figcaption>
                {project.title}{project.year ? `, ${project.year}` : ''}
              </figcaption>
            </figure>
          </a>
        ))
      }
    </section>
  </main>
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    background: #ffffff;
    color: #111111;
  }

  :global(body.works-gallery-page) {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.25;
  }

  .works-layout {
    min-height: 100svh;
    background: #ffffff;
  }

  .works-sidebar {
    position: fixed;
    inset: 0 auto 0 0;
    z-index: 20;
    width: 180px;
    height: 100svh;
    padding: 10px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: #ffffff;
  }

  .works-site-name,
  .works-sidebar a,
  .cover-item {
    color: inherit;
    text-decoration: none;
  }

  .works-site-name:hover,
  .works-sidebar a:hover,
  .cover-item:hover {
    opacity: 0.52;
  }

  .works-sidebar-bottom nav {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: 28px;
  }

  .works-sidebar-bottom p {
    margin: 0;
  }

  .cover-grid {
    margin-left: 180px;
    padding: 24px 34px 140px 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    column-gap: clamp(40px, 4.2vw, 70px);
    row-gap: clamp(100px, 12vw, 190px);
    align-items: start;
  }

  .cover-item {
    display: block;
    width: 100%;
    max-width: 400px;
    justify-self: center;
  }

  .cover-item figure {
    margin: 0;
  }

  .cover-media {
    width: 100%;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .cover-item img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 64svh;
    object-fit: contain;
  }

  .cover-item figcaption {
    margin-top: 8px;
    text-align: center;
  }

  @media (max-width: 1000px) {
    .cover-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .works-sidebar {
      position: relative;
      width: 100%;
      height: auto;
      min-height: 118px;
    }

    .works-sidebar-bottom {
      margin-top: 34px;
    }

    .works-sidebar-bottom nav {
      margin-bottom: 12px;
    }

    .cover-grid {
      margin-left: 0;
      padding: 18px 18px 80px;
      grid-template-columns: 1fr;
      row-gap: 76px;
    }

    .cover-item {
      width: min(84vw, 520px);
      max-width: none;
    }

    .cover-item img {
      max-height: none;
    }
  }
</style>
