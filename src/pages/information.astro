---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
---
<BaseLayout title="Information" bodyClass="information-page">
  <article class="information-grid">
    <section class="information-intro">
      <h1>{site.headline}</h1>
    </section>

    <section class="information-contact" aria-label="Contact information">
      <p>{site.location}</p>
      <p><a href={site.instagram} target="_blank" rel="noreferrer">{site.instagramLabel || 'Instagram'} ↗</a></p>
      <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
    </section>

    {site.copyright && <p class="information-note">{site.copyright}</p>}
  </article>
</BaseLayout>
