---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProjects } from '../lib/content.js';
import site from '../data/site.json';

const projects = getProjects();
const year = new Date().getFullYear();

const desktopColumns = [[], [], []];
const mobileColumns = [[], []];

projects.forEach((project, index) => {
  desktopColumns[index % 3].push(project);
  mobileColumns[index % 2].push(project);
});
---

<BaseLayout
  title="Works"
  showChrome={false}
  bodyClass="sq-works-page"
>
  <div class="sq-works-layout">

    <aside class="sq-works-sidebar">
      <a class="sq-works-name" href="/">
        {site.name}
      </a>

      <div class="sq-works-sidebar-bottom">
        <nav aria-label="Main navigation">
          <a href="/works/">Works.</a>
          <a href="/information/">Information.</a>
        </nav>

        <p class="sq-desktop-copyright">
          © {year}
        </p>
      </div>
    </aside>

    <!-- 电脑版：三列瀑布流 -->
    <section
      class="sq-masonry sq-masonry-desktop"
      aria-label="Projects"
    >
      {
        desktopColumns.map((column) => (
          <div class="sq-masonry-column">
            {
              column.map((project) => (
                <article class="sq-work-item">
                  <a
                    class="sq-work-link"
                    href={`/projects/${project.slug}/`}
                  >
                    <figure class="sq-work-figure">
                      <img
                        class="sq-work-cover"
                        src={project.cover}
                        alt={project.title}
                        loading="lazy"
                      />

                      <figcaption class="sq-work-caption">
                        {project.title}
                        {project.year ? `, ${project.year}` : ''}
                      </figcaption>
                    </figure>
                  </a>
                </article>
              ))
            }
          </div>
        ))
      }
    </section>

    <!-- 手机版：两列独立排列 -->
    <section
      class="sq-masonry sq-masonry-mobile"
      aria-label="Projects"
    >
      {
        mobileColumns.map((column) => (
          <div class="sq-masonry-column">
            {
              column.map((project) => (
                <article class="sq-work-item">
                  <a
                    class="sq-work-link"
                    href={`/projects/${project.slug}/`}
                  >
                    <figure class="sq-work-figure">
                      <img
                        class="sq-work-cover"
                        src={project.cover}
                        alt={project.title}
                        loading="lazy"
                      />

                      <figcaption class="sq-work-caption">
                        {project.title}
                        {project.year ? `, ${project.year}` : ''}
                      </figcaption>
                    </figure>
                  </a>
                </article>
              ))
            }
          </div>
        ))
      }
    </section>

    <!-- 手机版版权：正常放在全部项目后面 -->
    <p class="sq-mobile-copyright">
      © {year}
    </p>

  </div>
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    background: #ffffff;
    color: #111111;
  }

  :global(body.sq-works-page) {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.25;
  }

  :global(body.sq-works-page .skip-link) {
    position: fixed;
    top: -1000px;
    left: -1000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .sq-works-layout {
    min-height: 100svh;
    background: #ffffff;
  }

  /* ---------- 左侧导航 ---------- */

  .sq-works-sidebar {
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    z-index: 20;
    width: 180px;
    height: 100svh;
    padding: 10px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: #ffffff;
  }

  .sq-works-name,
  .sq-works-sidebar a,
  .sq-work-link {
    color: #111111;
    text-decoration: none;
  }

  .sq-works-name:hover,
  .sq-works-sidebar a:hover,
  .sq-work-link:hover {
    opacity: 0.55;
  }

  .sq-works-sidebar-bottom nav {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin: 0 0 28px;
  }

  .sq-desktop-copyright {
    margin: 0;
  }

  .sq-mobile-copyright {
    display: none;
  }

  /* ---------- 通用图片 ---------- */

  .sq-masonry {
    box-sizing: border-box;
  }

  .sq-masonry-column {
    flex: 1 1 0;
    min-width: 0;
  }

  .sq-work-item {
    width: 100%;
  }

  .sq-work-link,
  .sq-work-figure {
    display: block;
    width: 100%;
  }

  .sq-work-figure {
    margin: 0;
    padding: 0;
  }

  .sq-work-cover {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .sq-work-caption {
    display: block;
    width: 100%;
    margin: 7px 0 0;
    padding: 0;
    text-align: left;
  }

  /* ---------- 电脑版 ---------- */

  .sq-masonry-desktop {
    margin-left: 180px;
    padding: 34px 52px 120px 38px;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: clamp(40px, 4.5vw, 72px);
  }

  .sq-masonry-desktop .sq-masonry-column {
    max-width: 390px;
  }

  .sq-masonry-desktop .sq-work-item {
    margin: 0 0 clamp(58px, 6vw, 90px);
  }

  .sq-masonry-mobile {
    display: none;
  }

  @media (max-width: 1050px) and (min-width: 701px) {
    .sq-masonry-desktop {
      gap: 34px;
      padding-right: 34px;
    }
  }

  /* ---------- 手机版 ---------- */

  @media (max-width: 700px) {
    .sq-works-sidebar {
      position: relative;
      width: 100%;
      height: 118px;
      min-height: 118px;
      padding: 12px;
      display: block;
    }

    .sq-works-name {
      position: absolute;
      top: 12px;
      left: 12px;
    }

    .sq-works-sidebar-bottom {
      position: absolute;
      top: 52px;
      left: 12px;
      margin: 0;
    }

    .sq-works-sidebar-bottom nav {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      margin: 0;
    }

    .sq-desktop-copyright {
      display: none;
    }

    .sq-masonry-desktop {
      display: none;
    }

    .sq-masonry-mobile {
      display: flex;
      width: 100%;
      margin: 0;
      padding: 18px 16px 36px;
      box-sizing: border-box;
      align-items: flex-start;
      gap: 20px;
    }

    .sq-masonry-mobile .sq-masonry-column {
      width: calc(50% - 10px);
      max-width: none;
      flex: 0 0 calc(50% - 10px);
    }

    .sq-masonry-mobile .sq-work-item {
      margin: 0 0 42px;
    }

    .sq-masonry-mobile .sq-work-caption {
      margin-top: 7px;
      text-align: left;
      font-size: 11px;
      line-height: 1.2;
    }

    .sq-mobile-copyright {
      display: block;
      margin: 0;
      padding: 0 16px
        calc(18px + env(safe-area-inset-bottom));
      font-size: 10px;
    }
  }
</style>
