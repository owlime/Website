---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProjects } from '../../lib/content.js';
import site from '../../data/site.json';

export function getStaticPaths() {
  return getProjects().map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
const year = new Date().getFullYear();

/*
 * cover 只用于 /works/ 封面墙。
 * 项目详情页只读取 gallery；gallery 为空时才退回 cover。
 */
const images =
  project.gallery?.length > 0
    ? project.gallery
    : project.cover
      ? [project.cover]
      : [];
---

<BaseLayout
  title={project.title}
  showChrome={false}
  bodyClass="project-gallery-page"
>
  <main class="project-layout">
    <aside class="project-sidebar">
      <a class="project-site-name" href="/">{site.name}</a>

      <p class="project-title">
        {project.title}{project.year ? `, ${project.year}` : ''}
      </p>

      <div class="project-sidebar-bottom">
        <nav aria-label="Main navigation">
          <a href="/works/">Works.</a>
          <a href="/information/">Information.</a>
        </nav>
        <p>© {year}</p>
      </div>
    </aside>

    <section class="project-content">
      <div class="project-images">
        {
          images.map((image, index) => (
            <figure>
              <img
                src={image}
                alt={`${project.title} — image ${index + 1}`}
                loading={index === 0 ? 'eager' : 'lazy'}
              />
            </figure>
          ))
        }
      </div>

      {
        project.credits?.length > 0 && (
          <footer class="project-credits">
            {
              project.credits.map((credit) => (
                <div class="credit-row">
                  <span>{credit.role}</span>
                  <span>{credit.name}</span>
                </div>
              ))
            }
          </footer>
        )
      }
    </section>
  </main>
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    background: #ffffff;
    color: #111111;
  }

  :global(body.project-gallery-page) {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.25;
  }

  .project-layout {
    min-height: 100svh;
    background: #ffffff;
  }

  .project-sidebar {
    position: fixed;
    inset: 0 auto 0 0;
    z-index: 20;
    width: 190px;
    height: 100svh;
    padding: 10px;
    box-sizing: border-box;
    display: grid;
    grid-template-rows: auto 1fr auto;
    background: #ffffff;
  }

  .project-site-name,
  .project-sidebar a {
    color: inherit;
    text-decoration: none;
  }

  .project-site-name:hover,
  .project-sidebar a:hover {
    opacity: 0.52;
  }

  .project-title {
    align-self: center;
    max-width: 160px;
    margin: 0;
  }

  .project-sidebar-bottom nav {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: 28px;
  }

  .project-sidebar-bottom p {
    margin: 0;
  }

  .project-content {
    margin-left: 190px;
    padding: 0 48px 54px;
  }

  .project-images {
    width: min(72vw, 980px);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: clamp(56px, 7vw, 100px);
  }

  .project-images figure {
    width: 100%;
    margin: 0;
    display: flex;
    justify-content: center;
  }

  .project-images img {
    display: block;
    width: auto;
    max-width: 100%;
    height: auto;
    max-height: 92svh;
    object-fit: contain;
  }

  .project-credits {
    width: min(430px, 42vw);
    margin: 72px 0 0 auto;
    padding-bottom: 18px;
  }

  .credit-row {
    display: grid;
    grid-template-columns: minmax(120px, 1fr) minmax(150px, 1.2fr);
    gap: 22px;
    padding: 2px 0;
  }

  @media (max-width: 700px) {
    .project-sidebar {
      position: relative;
      width: 100%;
      height: auto;
      min-height: 154px;
      display: flex;
      flex-direction: column;
    }

    .project-title {
      order: 2;
      align-self: auto;
      max-width: none;
      margin-top: 34px;
    }

    .project-sidebar-bottom {
      order: 3;
      margin-top: 30px;
    }

    .project-sidebar-bottom nav {
      margin-bottom: 12px;
    }

    .project-content {
      margin-left: 0;
      padding: 10px 14px 40px;
    }

    .project-images {
      width: 100%;
      gap: 46px;
    }

    .project-images img {
      max-height: none;
    }

    .project-credits {
      width: 100%;
      margin-top: 54px;
    }

    .credit-row {
      grid-template-columns: 1fr 1.2fr;
      gap: 14px;
    }
  }
</style>
