---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';

const year = new Date().getFullYear();
---

<BaseLayout
  title="Information"
  showChrome={false}
  bodyClass="information-page"
>
  <main class="information-layout">
    <aside class="information-sidebar">
      <a class="information-site-name" href="/">
        {site.name}
      </a>

      <div class="information-sidebar-bottom">
        <nav aria-label="Main navigation">
          <a href="/works/">Works.</a>
          <a href="/information/">Information.</a>
        </nav>

        <p>© {year}</p>
      </div>
    </aside>

    <section class="information-content">
      <p class="information-headline">
        {site.headline}
      </p>

      <div class="information-contact">
        <p>{site.location}</p>

        <a href={`mailto:${site.email}`}>
          {site.email}
        </a>

        <p class="instagram-line">
          Instagram:
          <a
            href={site.instagram}
            target="_blank"
            rel="noreferrer"
          >
            @owlime
          </a>
        </p>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    background: #ffffff;
    color: #111111;
  }

  :global(body.information-page) {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.25;
  }

  .information-layout {
    min-height: 100svh;
    background: #ffffff;
  }

  .information-sidebar {
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    width: 180px;
    height: 100svh;
    padding: 10px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: #ffffff;
  }

  .information-site-name,
  .information-sidebar a,
  .information-contact a {
    color: inherit;
    text-decoration: none;
  }

  .information-site-name:hover,
  .information-sidebar a:hover,
  .information-contact a:hover {
    opacity: 0.5;
  }

  .information-sidebar-bottom nav {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: 28px;
  }

  .information-sidebar-bottom p {
    margin: 0;
  }

  .information-content {
    margin-left: 180px;
    padding: 34px 30px 80px;
    width: 440px;
    box-sizing: border-box;
  }

  .information-headline {
    margin: 0;
  }

  .information-contact {
    margin-top: 42px;
  }

  .information-contact p {
    margin: 0;
  }

  .information-contact > a {
    display: block;
    margin-top: 38px;
  }

  .instagram-line {
    margin-top: 4px !important;
  }

  @media (max-width: 700px) {
    .information-sidebar {
      position: relative;
      width: 100%;
      height: auto;
      min-height: 118px;
    }

    .information-sidebar-bottom {
      margin-top: 34px;
    }

    .information-sidebar-bottom nav {
      margin-bottom: 12px;
    }

    .information-content {
      margin-left: 0;
      padding: 36px 18px 80px;
      width: 100%;
    }
  }
</style>
