---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProjects } from '../lib/content.js';
import site from '../data/site.json';

const projects = getProjects();
const year = new Date().getFullYear();
---

<BaseLayout
  title="Works"
  showChrome={false}
  bodyClass="works-page"
>
  <main class="sq-works">

    <aside class="sq-works-sidebar">
      <a class="sq-works-name" href="/">
        {site.name}
      </a>

      <div class="sq-works-sidebar-bottom">
        <nav aria-label="Main navigation">
          <a href="/works/">Works.</a>
          <a href="/information/">Information.</a>
        </nav>

        <p>© {year}</p>
      </div>
    </aside>

    <section class="sq-works-grid" aria-label="Projects">
      {
        projects.map((project) => (
          <article class="sq-work-item">
            <a
              class="sq-work-link"
              href={`/projects/${project.slug}/`}
            >
              <div class="sq-work-image">
                <img
                  src={project.cover}
                  alt={project.title}
                  loading="lazy"
                />
              </div>

              <p class="sq-work-caption">
                {project.title}
                {project.year ? `, ${project.year}` : ''}
              </p>
            </a>
          </article>
        ))
      }
    </section>

  </main>
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    background: #ffffff;
    color: #111111;
  }

  :global(body.works-page) {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.25;
  }

  .sq-works {
    min-height: 100svh;
    background: #ffffff;
  }

  .sq-works-sidebar {
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    z-index: 20;
    width: 180px;
    height: 100svh;
    padding: 10px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: #ffffff;
  }

  .sq-works-name,
  .sq-works-sidebar a,
  .sq-work-link {
    color: #111111;
    text-decoration: none;
  }

  .sq-works-name:hover,
  .sq-works-sidebar a:hover,
  .sq-work-link:hover {
    opacity: 0.55;
  }

  .sq-works-sidebar-bottom nav {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: 28px;
  }

  .sq-works-sidebar-bottom p {
    margin: 0;
  }

  .sq-works-grid {
    margin-left: 180px;
    padding: 24px 38px 120px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    column-gap: clamp(38px, 4.5vw, 76px);
    row-gap: clamp(110px, 14vw, 210px);
    box-sizing: border-box;
  }

  .sq-work-item {
    width: 100%;
    max-width: 380px;
    justify-self: center;
  }

  .sq-work-link {
    display: block;
  }

  .sq-work-image {
    width: 100%;
  }

  .sq-work-image img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .sq-work-caption {
    margin: 7px 0 0;
    text-align: left;
  }

  @media (max-width: 900px) and (min-width: 701px) {
    .sq-works-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .sq-works-sidebar {
      position: relative;
      width: 100%;
      height: 92px;
      min-height: 92px;
      padding: 12px;
      display: block;
    }

    .sq-works-sidebar-bottom {
      position: absolute;
      top: 12px;
      right: 12px;
      left: auto;
      display: flex;
      align-items: baseline;
      gap: 10px;
    }

    .sq-works-sidebar-bottom nav {
      display: flex;
      flex-direction: row;
      align-items: baseline;
      gap: 4px;
      margin: 0;
    }

    .sq-works-sidebar-bottom p {
      margin: 0;
      white-space: nowrap;
    }

    .sq-works-grid {
      margin-left: 0;
      padding: 12px 20px 80px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 28px;
      row-gap: 72px;
    }

    .sq-work-item {
      width: 100%;
      min-width: 0;
      max-width: none;
    }

    .sq-work-image {
      width: 100%;
      aspect-ratio: 3 / 4;
      overflow: hidden;
      background: #f2f2f2;
    }

    .sq-work-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .sq-work-caption {
      margin-top: 7px;
      text-align: center;
      font-size: 11px;
      line-height: 1.2;
    }
  }
</style>
