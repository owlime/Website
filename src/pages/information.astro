---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';

const year = new Date().getFullYear();
---

<BaseLayout
  title="Information"
  showChrome={false}
  bodyClass="information-page"
>
  <main class="information-layout">

    <aside class="information-sidebar">
      <a class="information-site-name" href="/">{site.name}</a>

      <div class="information-sidebar-bottom">
        <nav aria-label="Main navigation">
          <a href="/works/">Works.</a>
          <a href="/information/">Information.</a>
        </nav>

        <p>© {year}</p>
      </div>
    </aside>

    <section class="information-content">
      <h1>{site.headline}</h1>

      <div class="information-contact">
        <p>{site.location}</p>

        <a href={`mailto:${site.email}`}>
          {site.email}
        </a>

        <p class="instagram-line">
          <span>Instagram: </span>
          <a
            href={site.instagram}
            target="_blank"
            rel="noreferrer"
          >
            @owlime
          </a>
        </p>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    background: #ffffff;
    color: #111111;
  }

  :global(body.information-page) {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.25;
  }

  .information-layout {
    min-height: 100svh;
    background: #ffffff;
  }

  .information-sidebar {
    position: fixed;
    inset: 0 auto 0 0;
    z-index: 20;
    width: 180px;
    height: 100svh;
    padding: 10px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: #ffffff;
  }

  .information-site-name,
  .information-sidebar a,
  .information-contact a {
    color: inherit;
    text-decoration: none;
  }

  .information-site-name:hover,
  .information-sidebar a:hover,
  .information-contact a:hover {
    opacity: 0.52;
  }

  .information-sidebar-bottom nav {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: 28px;
  }

  .information-sidebar-bottom p {
    margin: 0;
  }

  .information-content {
    min-height: 100svh;
    margin-left: 180px;
    padding: 24px 34px 80px 0;
    box-sizing: border-box;
    display: grid;
    grid-template-columns: minmax(260px, 1fr) minmax(280px, 0.8fr);
    column-gap: clamp(80px, 12vw, 220px);
    align-content: start;
  }

  .information-content h1 {
    margin: 0;
    max-width: 340px;
    font: inherit;
  }

  .information-contact {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .information-contact > p:first-child {
    margin: 0 0 38px;
  }

  .information-contact > a {
    display: block;
    margin-bottom: 4px;
  }

  .instagram-line {
    margin: 0;
  }

  @media (max-width: 700px) {
    .information-sidebar {
      position: relative;
      width: 100%;
      height: auto;
      min-height: 118px;
    }

    .information-sidebar-bottom {
      margin-top: 34px;
    }

    .information-sidebar-bottom nav {
      margin-bottom: 12px;
    }

    .information-content {
      min-height: auto;
      margin-left: 0;
      padding: 24px 18px 80px;
      grid-template-columns: 1fr;
      row-gap: 70px;
    }
  }
</style>
