---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';

const year = new Date().getFullYear();
---

<BaseLayout
  title="Information"
  showChrome={false}
  bodyClass="information-page"
>
  <main class="sq-info-page">

    <aside class="sq-info-sidebar">
      <a class="sq-info-name" href="/">
        {site.name}
      </a>

      <div class="sq-info-navigation-wrap">
        <nav class="sq-info-navigation" aria-label="Main navigation">
          <a href="/works/">Works.</a>
          <a href="/information/">Information.</a>
        </nav>
      </div>

      <p class="sq-info-copyright">
        © {year}
      </p>
    </aside>

    <section class="sq-info-content">
      <p class="sq-info-headline">
        {site.headline}
      </p>

      <div class="sq-info-details">
        <p class="sq-info-location">
          {site.location}
        </p>

        <a
          class="sq-info-email"
          href={`mailto:${site.email}`}
        >
          {site.email}
        </a>

        <p class="sq-info-instagram">
          Instagram:
          <a
            href={site.instagram}
            target="_blank"
            rel="noreferrer"
          >
            @owlime
          </a>
        </p>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    background: #ffffff;
    color: #111111;
  }

  :global(body.information-page) {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.25;
  }

  :global(body.information-page .skip-link) {
    position: fixed;
    top: -1000px;
    left: -1000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .sq-info-page {
    min-height: 100svh;
    background: #ffffff;
  }

  .sq-info-sidebar {
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    width: 180px;
    height: 100svh;
    padding: 10px;
    box-sizing: border-box;
    background: #ffffff;
  }

  .sq-info-name,
  .sq-info-navigation a,
  .sq-info-details a {
    color: #111111;
    text-decoration: none;
  }

  .sq-info-name:hover,
  .sq-info-navigation a:hover,
  .sq-info-details a:hover {
    opacity: 0.5;
  }

  .sq-info-navigation-wrap {
    position: absolute;
    bottom: 48px;
    left: 10px;
  }

  .sq-info-navigation {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .sq-info-copyright {
    position: absolute;
    bottom: 10px;
    left: 10px;
    margin: 0;
  }

  .sq-info-content {
    width: 440px;
    margin-left: 180px;
    padding: 34px 30px 80px;
    box-sizing: border-box;
  }

  .sq-info-headline {
    margin: 0;
  }

  .sq-info-details {
    margin-top: 42px;
  }

  .sq-info-location {
    margin: 0;
  }

  .sq-info-email {
    display: block;
    width: fit-content;
    margin-top: 38px;
  }

  .sq-info-instagram {
    margin: 4px 0 0;
  }

  @media (max-width: 700px) {
    .sq-info-page {
      position: relative;
      min-height: 100svh;
      padding-bottom: 54px;
      box-sizing: border-box;
    }

    .sq-info-sidebar {
      position: relative;
      width: 100%;
      height: 150px;
      min-height: 150px;
      padding: 12px;
    }

    .sq-info-name {
      position: absolute;
      top: 12px;
      left: 12px;
    }

    .sq-info-navigation-wrap {
      position: absolute;
      top: 64px;
      left: 12px;
      bottom: auto;
    }

    .sq-info-navigation {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
    }

    .sq-info-copyright {
      position: fixed;
      bottom: 12px;
      left: 12px;
      z-index: 40;
      margin: 0;
      padding-right: 6px;
      background: rgba(255, 255, 255, 0.96);
    }

    .sq-info-content {
      width: 100%;
      margin-left: 0;
      padding: 42px 38px 100px;
      box-sizing: border-box;
    }

    .sq-info-headline,
    .sq-info-details {
      width: min(100%, 360px);
    }

    .sq-info-details {
      margin-top: 44px;
    }

    .sq-info-email {
      margin-top: 38px;
    }
  }
</style>
