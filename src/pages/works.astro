---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProjects } from '../lib/content.js';
import site from '../data/site.json';

const projects = getProjects();
const year = new Date().getFullYear();

/*
  手机版：
  第 1、3、5、7 个项目进入左列；
  第 2、4、6、8 个项目进入右列。
*/
const mobileColumns = [[], []];

projects.forEach((project, index) => {
  mobileColumns[index % 2].push(project);
});
---

<BaseLayout
  title="Works"
  showChrome={false}
  bodyClass="sq-works-page"
>
  <div class="sq-works-layout">

    <aside class="sq-works-sidebar">
      <a class="sq-works-name" href="/">
        {site.name}
      </a>

      <div class="sq-works-sidebar-bottom">
        <nav aria-label="Main navigation">
          <a href="/works/">Works.</a>
          <a href="/information/">Information.</a>
        </nav>

        <p class="sq-desktop-copyright">
          © {year}
        </p>
      </div>
    </aside>

    <!-- 电脑版：三列 -->
    <section
      class="sq-desktop-grid"
      aria-label="Projects"
    >
      {
        projects.map((project) => (
          <article class="sq-desktop-item">
            <a
              class="sq-work-link"
              href={`/projects/${project.slug}/`}
            >
              <figure class="sq-desktop-figure is-portrait">
                <img
                  class="sq-desktop-cover"
                  src={project.cover}
                  alt={project.title}
                  loading="lazy"
                  decoding="async"
                />

                <figcaption class="sq-desktop-caption">
                  {project.title}
                  {project.year ? `, ${project.year}` : ''}
                </figcaption>
              </figure>
            </a>
          </article>
        ))
      }
    </section>

    <!-- 手机版：两列独立排列 -->
    <section
      class="sq-mobile-masonry"
      aria-label="Projects"
    >
      {
        mobileColumns.map((column) => (
          <div class="sq-mobile-column">
            {
              column.map((project) => (
                <article class="sq-mobile-item">
                  <a
                    class="sq-work-link"
                    href={`/projects/${project.slug}/`}
                  >
                    <figure class="sq-mobile-figure">
                      <img
                        class="sq-mobile-cover"
                        src={project.cover}
                        alt={project.title}
                        loading="lazy"
                        decoding="async"
                      />

                      <figcaption class="sq-mobile-caption">
                        {project.title}
                        {project.year ? `, ${project.year}` : ''}
                      </figcaption>
                    </figure>
                  </a>
                </article>
              ))
            }
          </div>
        ))
      }
    </section>

    <p class="sq-mobile-copyright">
      © {year}
    </p>

  </div>

  <!-- 自动判断电脑端图片是横图、方图还是竖图 -->
  <script>
    const desktopImages =
      document.querySelectorAll('.sq-desktop-cover');

    const setOrientation = (image) => {
      if (!(image instanceof HTMLImageElement)) return;

      const figure = image.closest('.sq-desktop-figure');
      if (!figure) return;

      figure.classList.remove(
        'is-landscape',
        'is-square',
        'is-portrait'
      );

      const width = image.naturalWidth;
      const height = image.naturalHeight;

      if (!width || !height) {
        figure.classList.add('is-portrait');
        return;
      }

      const ratio = width / height;

      if (ratio >= 1.15) {
        figure.classList.add('is-landscape');
      } else if (ratio <= 0.88) {
        figure.classList.add('is-portrait');
      } else {
        figure.classList.add('is-square');
      }
    };

    desktopImages.forEach((image) => {
      if (!(image instanceof HTMLImageElement)) return;

      if (image.complete && image.naturalWidth) {
        setOrientation(image);
      } else {
        image.addEventListener(
          'load',
          () => setOrientation(image),
          { once: true }
        );
      }
    });
  </script>
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    background: #ffffff;
    color: #111111;
  }

  :global(body.sq-works-page) {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.25;
  }

  :global(body.sq-works-page .skip-link) {
    position: fixed;
    top: -1000px;
    left: -1000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .sq-works-layout {
    min-height: 100svh;
    background: #ffffff;
  }

  /* ========================================
     左侧导航
  ======================================== */

  .sq-works-sidebar {
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    z-index: 20;

    width: 180px;
    height: 100svh;
    padding: 10px;
    box-sizing: border-box;

    display: flex;
    flex-direction: column;
    justify-content: space-between;

    background: #ffffff;
  }

  .sq-works-name,
  .sq-works-sidebar a,
  .sq-work-link {
    color: #111111;
    text-decoration: none;
  }

  .sq-works-name:hover,
  .sq-works-sidebar a:hover,
  .sq-work-link:hover {
    opacity: 0.55;
  }

  .sq-works-sidebar-bottom nav {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin: 0 0 28px;
  }

  .sq-desktop-copyright {
    margin: 0;
  }

  .sq-mobile-copyright {
    display: none;
  }

  /* ========================================
     电脑端：三列
  ======================================== */

  .sq-desktop-grid {
    margin-left: 180px;
    padding: 24px 54px 110px 34px;
    box-sizing: border-box;

    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));

    column-gap: clamp(32px, 3.5vw, 56px);
    row-gap: 58px;

    align-items: start;
  }

  .sq-desktop-item {
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
  }

  .sq-desktop-item .sq-work-link {
    display: block;
    width: 100%;
  }

  /*
    每张图片的 Figure 根据图片比例决定宽度。
  */
  .sq-desktop-figure {
    display: flex;
    width: fit-content;
    max-width: 100%;
    margin: 0;
    padding: 0;

    flex-direction: column;
    align-items: flex-start;
  }

  /*
    第一列：靠左。
  */
  .sq-desktop-item:nth-child(3n + 1)
  .sq-desktop-figure {
    margin-left: 0;
    margin-right: auto;
  }

  /*
    第二列：在自己的列里居中。
  */
  .sq-desktop-item:nth-child(3n + 2)
  .sq-desktop-figure {
    margin-left: auto;
    margin-right: auto;
  }

  /*
    第三列：
    靠右排列，但整个项目向页面内部收一些，
    避免距离浏览器右边太近。
  */
  .sq-desktop-item:nth-child(3n + 3) {
    padding-right: clamp(26px, 2.6vw, 48px);
  }

  .sq-desktop-item:nth-child(3n + 3)
  .sq-desktop-figure {
    margin-left: auto;
    margin-right: 0;
  }

  .sq-desktop-cover {
    display: block;
    max-width: 100%;
    object-fit: contain;
  }

  /*
    竖图统一高度。
    图片不裁剪，宽度根据原图比例自动变化。
  */
  .sq-desktop-figure.is-portrait
  .sq-desktop-cover {
    width: auto;
    height: clamp(350px, 46svh, 500px);
    max-height: 500px;
  }

  /*
    横图占满自己的列宽。
  */
  .sq-desktop-figure.is-landscape {
    width: 100%;
  }

  .sq-desktop-figure.is-landscape
  .sq-desktop-cover {
    width: 100%;
    height: auto;
  }

  /*
    接近方形的图片稍微缩窄。
  */
  .sq-desktop-figure.is-square {
    width: 82%;
  }

  .sq-desktop-figure.is-square
  .sq-desktop-cover {
    width: 100%;
    height: auto;
  }

  /*
    标题始终和自己的图片左边缘对齐。
    中间列只是整个图片居中，标题文字本身仍左对齐。
  */
  .sq-desktop-caption {
    display: block;
    width: 100%;
    margin: 7px 0 0;
    padding: 0;
    text-align: left;
  }

  /*
    中等宽度电脑和平板横屏：
    使用两列。
  */
  @media (max-width: 1050px) and (min-width: 701px) {
    .sq-desktop-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 40px;
      padding-right: 34px;
    }

    .sq-desktop-item {
      padding-right: 0;
    }

    .sq-desktop-item:nth-child(odd)
    .sq-desktop-figure {
      margin-left: 0;
      margin-right: auto;
    }

    .sq-desktop-item:nth-child(even)
    .sq-desktop-figure {
      margin-left: auto;
      margin-right: 0;
    }

    .sq-desktop-figure.is-portrait
    .sq-desktop-cover {
      height: clamp(360px, 50svh, 510px);
    }
  }

  /* ========================================
     手机版默认隐藏
  ======================================== */

  .sq-mobile-masonry {
    display: none;
  }

  /* ========================================
     手机版：保持当前排版
  ======================================== */

  @media (max-width: 700px) {
    .sq-works-sidebar {
      position: relative;

      width: 100%;
      height: 118px;
      min-height: 118px;
      padding: 12px;

      display: block;
    }

    .sq-works-name {
      position: absolute;
      top: 12px;
      left: 12px;
    }

    .sq-works-sidebar-bottom {
      position: absolute;
      top: 52px;
      left: 12px;
      margin: 0;
    }

    .sq-works-sidebar-bottom nav {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      margin: 0;
    }

    .sq-desktop-copyright {
      display: none;
    }

    .sq-desktop-grid {
      display: none;
    }

    .sq-mobile-masonry {
      display: flex;

      width: 100%;
      margin: 0;
      padding: 18px 16px 36px;
      box-sizing: border-box;

      align-items: flex-start;
      gap: 20px;
    }

    .sq-mobile-column {
      width: calc(50% - 10px);
      min-width: 0;
      flex: 0 0 calc(50% - 10px);
    }

    .sq-mobile-item {
      width: 100%;
      margin: 0 0 42px;
    }

    .sq-mobile-figure {
      display: block;
      width: 100%;
      margin: 0;
      padding: 0;
    }

    .sq-mobile-cover {
      display: block;
      width: 100%;
      height: auto;
      object-fit: contain;
    }

    .sq-mobile-caption {
      display: block;
      width: 100%;
      margin: 7px 0 0;
      padding: 0;

      text-align: left;
      font-size: 11px;
      line-height: 1.2;
    }

    .sq-mobile-copyright {
      display: block;
      margin: 0;
      padding:
        0
        16px
        calc(18px + env(safe-area-inset-bottom));

      font-size: 10px;
    }
  }
</style>
