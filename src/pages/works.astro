---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProjects } from '../lib/content.js';
import site from '../data/site.json';

const projects = getProjects();
const year = new Date().getFullYear();

/*
  手机版使用两列独立排列：
  第 1、3、5、7 个项目在左列；
  第 2、4、6、8 个项目在右列。
*/
const mobileColumns = [[], []];

projects.forEach((project, index) => {
  mobileColumns[index % 2].push(project);
});
---

<BaseLayout
  title="Works"
  showChrome={false}
  bodyClass="sq-works-page"
>
  <div class="sq-works-layout">

    <aside class="sq-works-sidebar">
      <a class="sq-works-name" href="/">
        {site.name}
      </a>

      <div class="sq-works-sidebar-bottom">
        <nav aria-label="Main navigation">
          <a href="/works/">Works.</a>
          <a href="/information/">Information.</a>
        </nav>

        <p class="sq-desktop-copyright">
          © {year}
        </p>
      </div>
    </aside>

    <!-- 电脑版：三列整齐网格 -->
    <section
      class="sq-desktop-grid"
      aria-label="Projects"
    >
      {
        projects.map((project) => (
          <article class="sq-desktop-item">
            <a
              class="sq-work-link"
              href={`/projects/${project.slug}/`}
            >
              <figure class="sq-desktop-figure is-portrait">
                <div class="sq-desktop-media">
                  <img
                    class="sq-desktop-cover"
                    src={project.cover}
                    alt={project.title}
                    loading="lazy"
                    decoding="async"
                  />
                </div>

                <figcaption class="sq-desktop-caption">
                  {project.title}
                  {project.year ? `, ${project.year}` : ''}
                </figcaption>
              </figure>
            </a>
          </article>
        ))
      }
    </section>

    <!-- 手机版：保持两列瀑布效果 -->
    <section
      class="sq-mobile-masonry"
      aria-label="Projects"
    >
      {
        mobileColumns.map((column) => (
          <div class="sq-mobile-column">
            {
              column.map((project) => (
                <article class="sq-mobile-item">
                  <a
                    class="sq-work-link"
                    href={`/projects/${project.slug}/`}
                  >
                    <figure class="sq-mobile-figure">
                      <img
                        class="sq-mobile-cover"
                        src={project.cover}
                        alt={project.title}
                        loading="lazy"
                        decoding="async"
                      />

                      <figcaption class="sq-mobile-caption">
                        {project.title}
                        {project.year ? `, ${project.year}` : ''}
                      </figcaption>
                    </figure>
                  </a>
                </article>
              ))
            }
          </div>
        ))
      }
    </section>

    <p class="sq-mobile-copyright">
      © {year}
    </p>

  </div>

  <!-- 自动判断电脑端图片是横图、竖图还是方图 -->
  <script>
    const desktopImages =
      document.querySelectorAll('.sq-desktop-cover');

    const setOrientation = (image) => {
      if (!(image instanceof HTMLImageElement)) return;

      const figure = image.closest('.sq-desktop-figure');
      if (!figure) return;

      figure.classList.remove(
        'is-landscape',
        'is-square',
        'is-portrait'
      );

      const width = image.naturalWidth;
      const height = image.naturalHeight;

      if (!width || !height) {
        figure.classList.add('is-portrait');
        return;
      }

      const ratio = width / height;

      if (ratio >= 1.15) {
        figure.classList.add('is-landscape');
      } else if (ratio <= 0.88) {
        figure.classList.add('is-portrait');
      } else {
        figure.classList.add('is-square');
      }
    };

    desktopImages.forEach((image) => {
      if (!(image instanceof HTMLImageElement)) return;

      if (image.complete && image.naturalWidth) {
        setOrientation(image);
      } else {
        image.addEventListener(
          'load',
          () => setOrientation(image),
          { once: true }
        );
      }
    });
  </script>
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    background: #ffffff;
    color: #111111;
  }

  :global(body.sq-works-page) {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.25;
  }

  :global(body.sq-works-page .skip-link) {
    position: fixed;
    top: -1000px;
    left: -1000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .sq-works-layout {
    min-height: 100svh;
    background: #ffffff;
  }

  /* ========================================
     左侧导航
  ======================================== */

  .sq-works-sidebar {
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    z-index: 20;

    width: 180px;
    height: 100svh;
    padding: 10px;
    box-sizing: border-box;

    display: flex;
    flex-direction: column;
    justify-content: space-between;

    background: #ffffff;
  }

  .sq-works-name,
  .sq-works-sidebar a,
  .sq-work-link {
    color: #111111;
    text-decoration: none;
  }

  .sq-works-name:hover,
  .sq-works-sidebar a:hover,
  .sq-work-link:hover {
    opacity: 0.55;
  }

  .sq-works-sidebar-bottom nav {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin: 0 0 28px;
  }

  .sq-desktop-copyright {
    margin: 0;
  }

  .sq-mobile-copyright {
    display: none;
  }

  /* ========================================
     电脑端：三列网格
  ======================================== */

  .sq-desktop-grid {
    margin-left: 180px;
    padding: 22px 38px 110px 34px;
    box-sizing: border-box;

    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));

    column-gap: clamp(28px, 3vw, 46px);
    row-gap: 44px;

    align-items: start;
  }

  .sq-desktop-item {
    width: 100%;
    min-width: 0;
    display: block;
  }

  .sq-desktop-item .sq-work-link {
    display: block;
    width: 100%;
  }

  /*
    所有图片都和所在列的左侧对齐。
    Figure 的宽度会跟随图片类型改变。
  */
  .sq-desktop-figure {
    display: inline-flex;
    max-width: 100%;
    margin: 0;
    padding: 0;

    flex-direction: column;
    align-items: flex-start;
    vertical-align: top;
  }

  .sq-desktop-media {
    display: flex;
    max-width: 100%;
    align-items: flex-start;
    justify-content: flex-start;
  }

  .sq-desktop-cover {
    display: block;
    object-fit: contain;
  }

  /*
    竖图：
    所有竖图使用同一个高度。
    宽度根据原图比例自动变化，因此不会裁图。
  */
  .sq-desktop-figure.is-portrait {
    width: fit-content;
  }

  .sq-desktop-figure.is-portrait .sq-desktop-media {
    height: clamp(340px, 42svh, 460px);
  }

  .sq-desktop-figure.is-portrait .sq-desktop-cover {
    width: auto;
    height: 100%;
    max-width: 100%;
  }

  /*
    横图：
    使用完整列宽。

    三列布局下，横图自然高度大约是统一竖图高度的
    60%–70%，接近你要求的三分之二。
  */
  .sq-desktop-figure.is-landscape {
    display: flex;
    width: 100%;
  }

  .sq-desktop-figure.is-landscape .sq-desktop-media {
    width: 100%;
    height: auto;
  }

  .sq-desktop-figure.is-landscape .sq-desktop-cover {
    width: 100%;
    height: auto;
  }

  /*
    接近方形的图片：
    大小介于横图与竖图之间。
  */
  .sq-desktop-figure.is-square {
    display: flex;
    width: 84%;
  }

  .sq-desktop-figure.is-square .sq-desktop-media {
    width: 100%;
  }

  .sq-desktop-figure.is-square .sq-desktop-cover {
    width: 100%;
    height: auto;
  }

  .sq-desktop-caption {
    display: block;
    width: 100%;
    margin: 7px 0 0;
    padding: 0;
    text-align: left;
  }

  /* 中等尺寸电脑和平板横屏 */

  @media (max-width: 1050px) and (min-width: 701px) {
    .sq-desktop-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 38px;
      padding-right: 32px;
    }

    .sq-desktop-figure.is-portrait .sq-desktop-media {
      height: clamp(350px, 48svh, 490px);
    }
  }

  /* ========================================
     手机版默认隐藏
  ======================================== */

  .sq-mobile-masonry {
    display: none;
  }

  /* ========================================
     手机版：保持当前排版
  ======================================== */

  @media (max-width: 700px) {
    .sq-works-sidebar {
      position: relative;

      width: 100%;
      height: 118px;
      min-height: 118px;
      padding: 12px;

      display: block;
    }

    .sq-works-name {
      position: absolute;
      top: 12px;
      left: 12px;
    }

    .sq-works-sidebar-bottom {
      position: absolute;
      top: 52px;
      left: 12px;
      margin: 0;
    }

    .sq-works-sidebar-bottom nav {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      margin: 0;
    }

    .sq-desktop-copyright {
      display: none;
    }

    .sq-desktop-grid {
      display: none;
    }

    .sq-mobile-masonry {
      display: flex;

      width: 100%;
      margin: 0;
      padding: 18px 16px 36px;
      box-sizing: border-box;

      align-items: flex-start;
      gap: 20px;
    }

    .sq-mobile-column {
      width: calc(50% - 10px);
      min-width: 0;
      flex: 0 0 calc(50% - 10px);
    }

    .sq-mobile-item {
      width: 100%;
      margin: 0 0 42px;
    }

    .sq-mobile-figure {
      display: block;
      width: 100%;
      margin: 0;
      padding: 0;
    }

    .sq-mobile-cover {
      display: block;
      width: 100%;
      height: auto;
      object-fit: contain;
    }

    .sq-mobile-caption {
      display: block;
      width: 100%;
      margin: 7px 0 0;
      padding: 0;

      text-align: left;
      font-size: 11px;
      line-height: 1.2;
    }

    .sq-mobile-copyright {
      display: block;
      margin: 0;
      padding:
        0
        16px
        calc(18px + env(safe-area-inset-bottom));

      font-size: 10px;
    }
  }
</style>
