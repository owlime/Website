---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProjects } from '../lib/content.js';
import site from '../data/site.json';

const projects = getProjects();
const heroImage = projects[0]?.cover;
---
<BaseLayout showChrome={false} bodyClass="landing-page">
  <section class="home-screen" aria-label="Portfolio entrance">
    <div class="home-identity">
      <a href="/">{site.name}</a>
      <p>{site.headline}</p>
    </div>

    <nav class="home-navigation" aria-label="Main navigation">
      <a href="/works/">Works</a><span aria-hidden="true">,</span>
      <a href="/information/">Information.</a>
    </nav>

    {heroImage ? (
      <a class="home-hero" href="/works/" aria-label="Enter the portfolio gallery">
        <img src={heroImage} alt="Enter the SHEN QU portfolio gallery" />
      </a>
    ) : (
      <a class="home-hero home-hero-empty" href="/works/">Enter gallery</a>
    )}

    <div class="home-meta" aria-label="Location and copyright">
      <span>© {new Date().getFullYear()}</span>
      <span>{site.location}</span>
    </div>
  </section>
</BaseLayout>
