---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProjects } from '../lib/content.js';
import site from '../data/site.json';

const projects = getProjects();
const heroImage = projects[0]?.cover;
const year = new Date().getFullYear();
---

<BaseLayout showChrome={false} bodyClass="landing-page">
  <section class="sq-home" aria-label="Portfolio entrance">

    <a class="sq-home-name" href="/">
      {site.name}
    </a>

    <nav class="sq-home-nav" aria-label="Main navigation">
      <a href="/works/">Works.</a>
      <a href="/information/">Information.</a>
    </nav>

    {heroImage ? (
      <a
        class="sq-home-image"
        href="/works/"
        aria-label="Enter portfolio gallery"
      >
        <img
          src={heroImage}
          alt="Enter the SHEN QU portfolio gallery"
        />
      </a>
    ) : (
      <a
        class="sq-home-image sq-home-placeholder"
        href="/works/"
      >
        Enter gallery
      </a>
    )}

    <p class="sq-home-copyright">
      © {year}
    </p>

  </section>
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    background: #ffffff;
    color: #111111;
  }

  :global(body.landing-page) {
    overflow: hidden;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.25;
  }

  .sq-home {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 100svh;
    overflow: hidden;
    background: #ffffff;
  }

  .sq-home-name {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 20;
    color: #111111;
    text-decoration: none;
  }

  .sq-home-nav {
    position: absolute;
    top: 50%;
    left: 10px;
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    transform: translateY(-50%);
  }

  .sq-home-nav a {
    color: #111111;
    text-decoration: none;
  }

  .sq-home-name:hover,
  .sq-home-nav a:hover {
    opacity: 0.5;
  }

  .sq-home-image {
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(48vw, 640px);
    height: min(68svh, 760px);
    transform: translate(-50%, -48%);
    display: grid;
    place-items: center;
    text-decoration: none;
  }

  .sq-home-image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .sq-home-placeholder {
    background: #f5f5f5;
    color: #111111;
  }

  .sq-home-copyright {
    position: absolute;
    bottom: 10px;
    left: 10px;
    z-index: 20;
    margin: 0;
    font-size: 10px;
  }

  @media (max-width: 700px) {
    .sq-home-name {
      top: 12px;
      left: 12px;
      font-size: 12px;
    }

    .sq-home-nav {
      top: 52px;
      left: 12px;
      transform: none;
      font-size: 12px;
    }

    .sq-home-image {
      top: 128px;
      left: 16px;
      width: calc(100vw - 32px);
      height: calc(100svh - 230px);
      transform: none;
    }

    .sq-home-image img {
      object-fit: contain;
    }

    .sq-home-copyright {
      bottom: 12px;
      left: 12px;
    }
  }
</style>
