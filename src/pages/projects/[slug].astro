---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProjects } from '../../lib/content.js';
import site from '../../data/site.json';

export function getStaticPaths() {
  return getProjects().map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
const year = new Date().getFullYear();

const images =
  project.gallery?.length > 0
    ? project.gallery
    : project.cover
      ? [project.cover]
      : [];
---

<BaseLayout
  title={project.title}
  showChrome={false}
  bodyClass="project-gallery-page"
>
  <main class="project-layout">

    <aside class="project-sidebar">
      <a class="project-site-name" href="/">
        {site.name}
      </a>

      <p class="project-title">
        {project.title}
        {project.year ? `, ${project.year}` : ''}
      </p>

      <div class="project-sidebar-bottom">
        <nav aria-label="Main navigation">
          <a href="/works/">Works.</a>
          <a href="/information/">Information.</a>
        </nav>

        <p class="desktop-copyright">
          © {year}
        </p>
      </div>
    </aside>

    <section class="project-content">
      <div class="project-images">
        {
          images.map((image, index) => (
            <figure>
              <img
                src={image}
                alt={`${project.title} — image ${index + 1}`}
                loading={index === 0 ? 'eager' : 'lazy'}
              />
            </figure>
          ))
        }
      </div>

      {
        project.credits?.length > 0 && (
          <footer class="project-credits">
            {
              project.credits.map((credit) => (
                <div class="credit-row">
                  <span>{credit.role}</span>
                  <span>{credit.name}</span>
                </div>
              ))
            }
          </footer>
        )
      }

      <p class="mobile-copyright">
        © {year}
      </p>
    </section>

  </main>
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    background: #ffffff;
    color: #111111;
  }

  :global(body.project-gallery-page) {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.25;
  }

  :global(body.project-gallery-page .skip-link) {
    position: fixed;
    top: -1000px;
    left: -1000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .project-layout {
    min-height: 100svh;
    background: #ffffff;
  }

  /* ---------- Desktop sidebar ---------- */

  .project-sidebar {
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    z-index: 20;
    width: 190px;
    height: 100svh;
    padding: 10px;
    box-sizing: border-box;
    display: grid;
    grid-template-rows: auto 1fr auto;
    background: #ffffff;
  }

  .project-site-name,
  .project-sidebar a {
    color: #111111;
    text-decoration: none;
  }

  .project-site-name:hover,
  .project-sidebar a:hover {
    opacity: 0.52;
  }

  .project-title {
    align-self: center;
    max-width: 160px;
    margin: 0;
  }

  .project-sidebar-bottom nav {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: 28px;
  }

  .desktop-copyright {
    margin: 0;
  }

  .mobile-copyright {
    display: none;
  }

  /* ---------- Project images ---------- */

  .project-content {
    margin-left: 190px;
    padding: 0 48px 54px;
  }

  .project-images {
    width: min(72vw, 980px);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: clamp(56px, 7vw, 100px);
  }

  .project-images figure {
    width: 100%;
    margin: 0;
    display: flex;
    justify-content: center;
  }

  .project-images img {
    display: block;
    width: auto;
    max-width: 100%;
    height: auto;
    max-height: 92svh;
    object-fit: contain;
  }

  .project-credits {
    width: min(430px, 42vw);
    margin: 72px 0 0 auto;
    padding-bottom: 18px;
  }

  .credit-row {
    display: grid;
    grid-template-columns: minmax(120px, 1fr) minmax(150px, 1.2fr);
    gap: 22px;
    padding: 2px 0;
  }

  /* ---------- Mobile ---------- */

  @media (max-width: 700px) {
    .project-sidebar {
      position: relative;
      width: 100%;
      height: 118px;
      min-height: 118px;
      padding: 12px;
      display: block;
    }

    .project-site-name {
      position: absolute;
      top: 12px;
      left: 12px;
    }

    .project-title {
      position: absolute;
      top: 58px;
      left: 12px;
      max-width: calc(100vw - 24px);
      margin: 0;
    }

    /* 手机版导航放在右上角，不再覆盖照片 */
    .project-sidebar-bottom {
      position: absolute;
      top: 12px;
      right: 12px;
      left: auto;
      bottom: auto;
      margin: 0;
      padding: 0;
      background: transparent;
    }

    .project-sidebar-bottom nav {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      margin: 0;
    }

    .desktop-copyright {
      display: none;
    }

    .project-content {
      margin-left: 0;
      padding: 12px 14px 24px;
    }

    .project-images {
      width: 100%;
      gap: 46px;
    }

    .project-images figure {
      width: 100%;
      margin: 0;
    }

    .project-images img {
      display: block;
      width: 100%;
      max-width: none;
      height: auto;
      max-height: none;
      object-fit: contain;
    }

    .project-credits {
      width: 100%;
      margin-top: 54px;
      padding-bottom: 20px;
    }

    .credit-row {
      grid-template-columns: 1fr 1.2fr;
      gap: 14px;
    }

    /* 版权正常放在所有内容结束后 */
    .mobile-copyright {
      display: block;
      margin: 52px 0 0;
      padding: 0 0
        calc(12px + env(safe-area-inset-bottom));
      font-size: 10px;
    }
  }
</style>
