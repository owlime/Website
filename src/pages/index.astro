---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProjects } from '../lib/content.js';
import site from '../data/site.json';

const projects = getProjects();
const heroImage = projects[0]?.cover;
---
<BaseLayout showChrome={false} bodyClass="landing-page">
  <section class="single-image-home" aria-label="Portfolio entrance">
    <header class="home-chrome">
      <a class="home-name" href="/">{site.name}</a>
      <nav class="home-nav" aria-label="Main navigation">
        <a href="/works/">Works</a><span aria-hidden="true">,</span>
        <a href="/information/">Information.</a>
      </nav>
    </header>

    {heroImage ? (
      <a class="home-image-link" href="/works/" aria-label="Enter portfolio gallery">
        <img src={heroImage} alt="Enter the SHEN QU portfolio gallery" />
      </a>
    ) : (
      <a class="home-image-link home-image-placeholder" href="/works/">Enter gallery</a>
    )}

    <div class="home-footer">
      <p>{site.headline}</p>
      <p>{site.location}</p>
      <p>© {new Date().getFullYear()}</p>
    </div>
  </section>
</BaseLayout>
