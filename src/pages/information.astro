---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';

const year = new Date().getFullYear();
---

<BaseLayout
  title="Information"
  showChrome={false}
  bodyClass="information-page"
>
  <main class="sq-info-page">

    <aside class="sq-info-sidebar">
      <a class="sq-info-name" href="/">
        {site.name}
      </a>

      <div class="sq-info-sidebar-bottom">
        <nav class="sq-info-navigation" aria-label="Main navigation">
          <a href="/works/">Works.</a>
          <a href="/information/">Information.</a>
        </nav>

        <p class="sq-info-copyright">© {year}</p>
      </div>
    </aside>

    <section class="sq-info-content">
      <p class="sq-info-headline">
        {site.headline}
      </p>

      <div class="sq-info-details">
        <p class="sq-info-location">
          {site.location}
        </p>

        <a
          class="sq-info-email"
          href={`mailto:${site.email}`}
        >
          {site.email}
        </a>

        <p class="sq-info-instagram">
          Instagram:
          <a
            href={site.instagram}
            target="_blank"
            rel="noreferrer"
          >
            @owlime
          </a>
        </p>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  :global(html) {
    margin: 0;
    padding: 0;
    background: #ffffff;
  }

  :global(body.information-page) {
    margin: 0;
    padding: 0;
    background: #ffffff;
    color: #111111;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.25;
  }

  .sq-info-page {
    position: relative;
    min-height: 100svh;
    width: 100%;
    background: #ffffff;
  }

  .sq-info-sidebar {
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    z-index: 10;
    width: 180px;
    height: 100svh;
    padding: 10px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: #ffffff;
  }

  .sq-info-name,
  .sq-info-navigation a,
  .sq-info-details a {
    color: #111111;
    text-decoration: none;
  }

  .sq-info-name:hover,
  .sq-info-navigation a:hover,
  .sq-info-details a:hover {
    opacity: 0.5;
  }

  .sq-info-sidebar-bottom {
    display: block;
  }

  .sq-info-navigation {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin: 0 0 28px;
    padding: 0;
  }

  .sq-info-copyright {
    margin: 0;
  }

  .sq-info-content {
    display: block;
    width: 440px;
    margin: 0 0 0 180px;
    padding: 34px 30px 80px;
    box-sizing: border-box;
  }

  .sq-info-headline {
    display: block;
    margin: 0;
    padding: 0;
  }

  .sq-info-details {
    display: block;
    width: 100%;
    margin: 42px 0 0;
    padding: 0;
  }

  .sq-info-location {
    display: block;
    margin: 0;
    padding: 0;
  }

  .sq-info-email {
    display: block;
    width: fit-content;
    margin: 38px 0 0;
    padding: 0;
  }

  .sq-info-instagram {
    display: block;
    margin: 4px 0 0;
    padding: 0;
  }

  @media (max-width: 700px) {
    .sq-info-sidebar {
      position: relative;
      width: 100%;
      height: auto;
      min-height: 118px;
    }

    .sq-info-sidebar-bottom {
      margin-top: 34px;
    }

    .sq-info-navigation {
      margin-bottom: 12px;
    }

    .sq-info-content {
      width: 100%;
      margin-left: 0;
      padding: 36px 18px 80px;
    }
  }
</style>
