---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProjects } from '../lib/content.js';
import site from '../data/site.json';

const projects = getProjects();
const year = new Date().getFullYear();

/*
  Desktop uses three independent columns so mixed image ratios
  do not create large empty grid rows.
  Mobile uses one normal two-column grid so the reading order stays exact.
*/
const desktopColumns = [[], [], []];

projects.forEach((project, index) => {
  desktopColumns[index % 3].push(project);
});
---

<BaseLayout
  title="Works"
  showChrome={false}
  bodyClass="sq-works-page"
>
  <div class="sq-works-layout">

    <aside class="sq-works-sidebar">
      <a class="sq-works-name" href="/">
        {site.name}
      </a>

      <div class="sq-works-sidebar-bottom">
        <nav aria-label="Main navigation">
          <a href="/works/">Works.</a>
          <a href="/information/">Information.</a>
        </nav>

        <p>© {year}</p>
      </div>
    </aside>

    <!-- Desktop: three-column masonry, no cropping -->
    <section
      class="sq-desktop-masonry"
      aria-label="Projects"
    >
      {
        desktopColumns.map((column) => (
          <div class="sq-desktop-column">
            {
              column.map((project) => (
                <article class="sq-work-item">
                  <a
                    class="sq-work-link"
                    href={`/projects/${project.slug}/`}
                  >
                    <figure class="sq-work-figure">
                      <img
                        class="sq-work-cover"
                        src={project.cover}
                        alt={project.title}
                        loading="lazy"
                      />

                      <figcaption class="sq-work-caption">
                        {project.title}
                        {project.year ? `, ${project.year}` : ''}
                      </figcaption>
                    </figure>
                  </a>
                </article>
              ))
            }
          </div>
        ))
      }
    </section>

    <!-- Mobile: normal two-column grid keeps exact Display order -->
    <section
      class="sq-mobile-grid"
      aria-label="Projects"
    >
      {
        projects.map((project) => (
          <article class="sq-mobile-item">
            <a
              class="sq-work-link"
              href={`/projects/${project.slug}/`}
            >
              <figure class="sq-work-figure">
                <img
                  class="sq-work-cover"
                  src={project.cover}
                  alt={project.title}
                  loading="lazy"
                />

                <figcaption class="sq-mobile-caption">
                  {project.title}
                  {project.year ? `, ${project.year}` : ''}
                </figcaption>
              </figure>
            </a>
          </article>
        ))
      }
    </section>

  </div>
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    background: #ffffff;
    color: #111111;
  }

  :global(body.sq-works-page) {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.25;
  }

  :global(body.sq-works-page .skip-link) {
    position: fixed;
    top: -1000px;
    left: -1000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .sq-works-layout {
    min-height: 100svh;
    background: #ffffff;
  }

  .sq-works-sidebar {
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    z-index: 20;
    width: 180px;
    height: 100svh;
    padding: 10px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: #ffffff;
  }

  .sq-works-name,
  .sq-works-sidebar a,
  .sq-work-link {
    color: #111111;
    text-decoration: none;
  }

  .sq-works-name:hover,
  .sq-works-sidebar a:hover,
  .sq-work-link:hover {
    opacity: 0.55;
  }

  .sq-works-sidebar-bottom nav {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin: 0 0 28px;
  }

  .sq-works-sidebar-bottom p {
    margin: 0;
  }

  /* Desktop masonry */

  .sq-desktop-masonry {
    margin-left: 180px;
    padding: 34px 52px 120px 38px;
    box-sizing: border-box;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: clamp(40px, 4.5vw, 72px);
  }

  .sq-desktop-column {
    flex: 1 1 0;
    min-width: 0;
    max-width: 390px;
  }

  .sq-work-item {
    width: 100%;
    margin: 0 0 clamp(58px, 6vw, 90px);
  }

  .sq-work-link,
  .sq-work-figure {
    display: block;
    width: 100%;
  }

  .sq-work-figure {
    margin: 0;
    padding: 0;
  }

  .sq-work-cover {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .sq-work-caption {
    display: block;
    width: 100%;
    margin: 7px 0 0;
    padding: 0;
    text-align: left;
  }

  .sq-mobile-grid {
    display: none;
  }

  @media (max-width: 1050px) and (min-width: 701px) {
    .sq-desktop-masonry {
      gap: 34px;
      padding-right: 34px;
    }
  }

  /* Mobile */

  @media (max-width: 700px) {
    .sq-works-sidebar {
      position: relative;
      width: 100%;
      height: 118px;
      min-height: 118px;
      padding: 12px;
      display: block;
    }

    .sq-works-name {
      position: absolute;
      top: 12px;
      left: 12px;
    }

    .sq-works-sidebar-bottom {
      position: absolute;
      top: 52px;
      left: 12px;
      margin: 0;
    }

    .sq-works-sidebar-bottom nav {
      margin: 0;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
    }

    .sq-works-sidebar-bottom p {
      position: fixed;
      bottom: calc(12px + env(safe-area-inset-bottom));
      left: 12px;
      z-index: 40;
      margin: 0;
      padding-right: 5px;
      background: rgba(255, 255, 255, 0.96);
      font-size: 10px;
    }

    .sq-desktop-masonry {
      display: none;
    }

    /*
      Normal grid preserves CMS order:
      1 left, 2 right, 3 left, 4 right.
    */
    .sq-mobile-grid {
      display: grid;
      width: 100%;
      margin: 0;
      padding: 18px 16px 100px;
      box-sizing: border-box;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 20px;
      row-gap: 52px;
      align-items: start;
    }

    .sq-mobile-item {
      display: block;
      width: 100%;
      min-width: 0;
      margin: 0;
    }

    .sq-mobile-caption {
      margin: 7px 0 0;
      text-align: center;
      font-size: 11px;
      line-height: 1.2;
    }
  }
</style>
