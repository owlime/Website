---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
---

<BaseLayout bodyClass="information-page">
  <section class="information">

    <h1 class="information-headline">
      {site.headline}
    </h1>

    <div class="information-contact">
      <p class="information-location">
        {site.location}
      </p>

      <a
        class="information-email"
        href={`mailto:${site.email}`}
      >
        {site.email}
      </a>

      <p class="information-instagram">
        <span>Instagram: </span>
        <a
          href={site.instagram}
          target="_blank"
          rel="noreferrer"
        >
          @owlime
        </a>
      </p>
    </div>

  </section>
</BaseLayout>

<style>
  :global(body.information-page) {
    background: #ffffff;
  }

  .information {
    position: relative;
    min-height: calc(100svh - 80px);
    padding: 70px 10px 40px;
    color: #111111;

    font-family: Arial, Helvetica, sans-serif;
    font-size: 13px;
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: 0;
  }

  .information-headline {
    position: absolute;
    top: 70px;
    left: 10px;
    max-width: 320px;
    margin: 0;

    font-family: inherit;
    font-size: inherit;
    font-weight: 400;
    line-height: inherit;
  }

  .information-contact {
    position: absolute;
    top: 70px;
    right: 22%;

    display: flex;
    flex-direction: column;
    align-items: flex-start;

    font-family: inherit;
    font-size: inherit;
    font-weight: 400;
  }

  .information-location {
    margin: 0 0 38px;
  }

  .information-email {
    display: block;
    margin: 0 0 4px;
  }

  .information-instagram {
    margin: 0;
  }

  .information a {
    color: inherit;
    text-decoration: none;
  }

  .information a:hover {
    opacity: 0.5;
  }

  @media (max-width: 700px) {
    .information {
      padding: 90px 10px 40px;
      font-size: 12px;
    }

    .information-headline {
      position: static;
      max-width: none;
    }

    .information-contact {
      position: static;
      margin-top: 70px;
    }
  }
</style>
